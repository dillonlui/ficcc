# Sanity CMS — server-side (GROQ queries during build)
SANITY_PROJECT_ID=
SANITY_DATASET=production

# Sanity Studio — client-side (PUBLIC_ prefix required for browser access)
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Sanity Visual Editing / Preview Mode
# Server-only token for fetching draft content (never use PUBLIC_ prefix)
SANITY_API_READ_TOKEN=
# Set to 'true' to enable draft preview mode and VisualEditing overlay
PUBLIC_SANITY_VISUAL_EDITING_ENABLED=
# URL of the preview site — used by Sanity Studio's Presentation tool iframe
PUBLIC_SANITY_PREVIEW_URL=

# Vercel deploy hook — create in Vercel Dashboard > Settings > Git > Deploy Hooks
# Used as the target URL for Sanity webhook on publish events
VERCEL_DEPLOY_HOOK_URL=

# YouTube Data API v3 — for fetching latest sermons from @FICCCenglish
YOUTUBE_API_KEY=

# Email delivery (Resend)
RESEND_API_KEY=

# Cloudflare Turnstile (spam protection)
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google Analytics 4 — measurement ID (e.g. G-XXXXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console — verification meta tag content
PUBLIC_GOOGLE_SITE_VERIFICATION=
