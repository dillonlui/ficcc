---
/* ConnectForm — newcomer connection form with Cloudflare Turnstile spam
   protection and client-side fetch submission to /api/connect.
   Adapted from ContactForm pattern. */
const siteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY ?? '';
---

<form class="connect-form" novalidate>
  <div class="connect-form__row">
    <div class="connect-form__field">
      <label class="connect-form__label" for="connect-name">Name <span aria-hidden="true">*</span></label>
      <input
        class="connect-form__input"
        type="text"
        id="connect-name"
        name="name"
        required
        minlength="2"
        autocomplete="name"
        placeholder="Your name"
      />
      <span class="connect-form__error" data-field="name"></span>
    </div>

    <div class="connect-form__field">
      <label class="connect-form__label" for="connect-email">Email <span aria-hidden="true">*</span></label>
      <input
        class="connect-form__input"
        type="email"
        id="connect-email"
        name="email"
        required
        autocomplete="email"
        placeholder="you@example.com"
      />
      <span class="connect-form__error" data-field="email"></span>
    </div>
  </div>

  <div class="connect-form__field">
    <label class="connect-form__label" for="connect-phone">Phone</label>
    <input
      class="connect-form__input"
      type="tel"
      id="connect-phone"
      name="phone"
      autocomplete="tel"
      placeholder="(optional)"
    />
    <span class="connect-form__error" data-field="phone"></span>
  </div>

  <div class="connect-form__field">
    <label class="connect-form__label" for="connect-interests">What are you interested in?</label>
    <textarea
      class="connect-form__input connect-form__textarea"
      id="connect-interests"
      name="interests"
      rows="3"
      placeholder="Small groups, volunteering, Bible study, worship team…"
    ></textarea>
    <span class="connect-form__error" data-field="interests"></span>
  </div>

  <div class="connect-form__field">
    <label class="connect-form__label" for="connect-message">Message</label>
    <textarea
      class="connect-form__input connect-form__textarea"
      id="connect-message"
      name="message"
      rows="3"
      placeholder="Anything else you'd like us to know? (optional)"
    ></textarea>
    <span class="connect-form__error" data-field="message"></span>
  </div>

  <!-- Cloudflare Turnstile widget -->
  <div class="connect-form__turnstile cf-turnstile" data-sitekey={siteKey} data-theme="light"></div>
  <span class="connect-form__error" data-field="turnstileToken"></span>

  <button class="connect-form__submit" type="submit">
    <span class="connect-form__submit-text">Connect With Us</span>
    <span class="connect-form__spinner" aria-hidden="true"></span>
  </button>

  <!-- General error banner -->
  <div class="connect-form__banner connect-form__banner--error" role="alert" hidden></div>

  <!-- Success message -->
  <div class="connect-form__banner connect-form__banner--success" role="status" hidden></div>
</form>

<script is:inline>
(function () {
  var form = document.querySelector('.connect-form');
  if (!form) return;

  var submitBtn = form.querySelector('.connect-form__submit');
  var submitText = form.querySelector('.connect-form__submit-text');
  var spinner = form.querySelector('.connect-form__spinner');
  var errorBanner = form.querySelector('.connect-form__banner--error');
  var successBanner = form.querySelector('.connect-form__banner--success');

  /* ---- Helpers ---- */

  function showFieldError(field, msg) {
    var el = form.querySelector('[data-field="' + field + '"]');
    if (el) {
      el.textContent = msg;
      el.hidden = false;
    }
    var input = form.querySelector('[name="' + field + '"]');
    if (input) input.classList.add('connect-form__input--error');
  }

  function clearErrors() {
    form.querySelectorAll('.connect-form__error').forEach(function (el) {
      el.textContent = '';
      el.hidden = true;
    });
    form.querySelectorAll('.connect-form__input--error').forEach(function (el) {
      el.classList.remove('connect-form__input--error');
    });
    errorBanner.hidden = true;
    errorBanner.textContent = '';
  }

  function setLoading(loading) {
    submitBtn.disabled = loading;
    submitText.textContent = loading ? 'Sending\u2026' : 'Connect With Us';
    spinner.hidden = !loading;
  }

  /* ---- Client-side validation ---- */

  var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function validate() {
    var errors = [];
    var name = form.querySelector('[name="name"]').value.trim();
    var email = form.querySelector('[name="email"]').value.trim();

    if (name.length < 2) {
      errors.push({ field: 'name', message: 'Name is required (min 2 characters)' });
    }
    if (!EMAIL_RE.test(email)) {
      errors.push({ field: 'email', message: 'A valid email address is required' });
    }
    return errors;
  }

  /* ---- Submission ---- */

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    clearErrors();
    successBanner.hidden = true;

    /* Client-side validation */
    var clientErrors = validate();
    if (clientErrors.length > 0) {
      clientErrors.forEach(function (err) { showFieldError(err.field, err.message); });
      return;
    }

    /* Get Turnstile token */
    var turnstileInput = form.querySelector('[name="cf-turnstile-response"]');
    var turnstileToken = turnstileInput ? turnstileInput.value : '';
    if (!turnstileToken) {
      showFieldError('turnstileToken', 'Please complete the captcha verification');
      return;
    }

    setLoading(true);

    var payload = {
      name: form.querySelector('[name="name"]').value.trim(),
      email: form.querySelector('[name="email"]').value.trim(),
      phone: form.querySelector('[name="phone"]').value.trim(),
      interests: form.querySelector('[name="interests"]').value.trim(),
      message: form.querySelector('[name="message"]').value.trim(),
      turnstileToken: turnstileToken,
    };

    try {
      var res = await fetch('/api/connect', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });

      var data = await res.json();

      if (!res.ok) {
        if (data.fields && Array.isArray(data.fields)) {
          data.fields.forEach(function (err) { showFieldError(err.field, err.message); });
        }
        errorBanner.textContent = data.error || 'Something went wrong. Please try again.';
        errorBanner.hidden = false;

        if (typeof turnstile !== 'undefined') {
          turnstile.reset();
        }
        return;
      }

      /* Success */
      successBanner.textContent = data.message || 'Thank you for reaching out! We will be in touch soon.';
      successBanner.hidden = false;
      form.reset();
      if (typeof turnstile !== 'undefined') {
        turnstile.reset();
      }
    } catch (err) {
      errorBanner.textContent = 'Network error. Please check your connection and try again.';
      errorBanner.hidden = false;
    } finally {
      setLoading(false);
    }
  });
})();
</script>

<style>
  .connect-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 36rem;
  }

  .connect-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .connect-form__field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .connect-form__label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
  }

  .connect-form__label span {
    color: var(--color-terracotta, #c0392b);
  }

  .connect-form__input {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-body);
    background-color: var(--color-bg);
    border: 1px solid var(--color-stone);
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-4);
    transition: border-color var(--transition), box-shadow var(--transition);
  }

  .connect-form__input::placeholder {
    color: var(--color-stone);
  }

  .connect-form__input:focus {
    outline: none;
    border-color: var(--color-focus);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-focus) 25%, transparent);
  }

  .connect-form__input--error {
    border-color: var(--color-terracotta, #c0392b);
  }

  .connect-form__textarea {
    resize: vertical;
    min-height: 5rem;
  }

  .connect-form__error {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-terracotta, #c0392b);
    min-height: 0;
  }

  .connect-form__error:empty,
  .connect-form__error[hidden] {
    display: none;
  }

  .connect-form__submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-bg);
    background-color: var(--color-terracotta);
    border: none;
    border-radius: var(--radius-sm);
    padding: var(--space-3) var(--space-8);
    cursor: pointer;
    transition: background-color var(--transition), box-shadow var(--transition), opacity var(--transition);
  }

  .connect-form__submit:hover:not(:disabled) {
    background-color: color-mix(in srgb, var(--color-terracotta) 85%, black);
  }

  .connect-form__submit:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .connect-form__submit:disabled {
    opacity: 0.7;
    cursor: not-allowed;
  }

  /* Spinner */
  .connect-form__spinner {
    display: none;
    width: 1em;
    height: 1em;
    border: 2px solid currentColor;
    border-right-color: transparent;
    border-radius: 50%;
    animation: connect-spin 0.6s linear infinite;
  }

  .connect-form__submit:disabled .connect-form__spinner {
    display: inline-block;
  }

  @keyframes connect-spin {
    to { transform: rotate(360deg); }
  }

  /* Banners */
  .connect-form__banner {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-sm);
  }

  .connect-form__banner[hidden] {
    display: none;
  }

  .connect-form__banner--error {
    color: #991b1b;
    background-color: #fef2f2;
    border: 1px solid #fecaca;
  }

  .connect-form__banner--success {
    color: #166534;
    background-color: #f0fdf4;
    border: 1px solid #bbf7d0;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 768px) {
    .connect-form__row {
      grid-template-columns: 1fr;
    }
  }
</style>
