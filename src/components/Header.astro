---
import { getNavLinks, type Lang } from '../lib/navigation';

interface Props {
  lang?: Lang;
  langToggleHref?: string;
}

const { lang = 'en', langToggleHref: langToggleHrefProp } = Astro.props;
const navLinks = getNavLinks(lang);
const logoHref = lang === 'zh' ? '/zh' : '/en/';
const logoText = lang === 'zh' ? '伊的家' : 'FICCC';
const logoLabel = lang === 'zh' ? '伊的家' : 'FICCC Home';
const langToggleLabel = lang === 'zh' ? '中文 / EN' : 'EN / 中文';
const langToggleHref = langToggleHrefProp ?? (lang === 'zh' ? '/en/' : '/zh');
const currentPath = Astro.url.pathname;
const logoSrc = lang === 'zh' ? '/logo/logo-zh-light.svg' : '/logo/logo-en-light.svg';

// Dropdown configurations — keyed by the nav link href that triggers the dropdown
interface DropdownConfig {
  subLinks: { label: string; href: string }[];
  activePrefixes: string[]; // paths that make this dropdown show as active
}

const aboutPrefix = lang === 'zh' ? '/zh/about' : '/en/about';

const dropdowns: Record<string, DropdownConfig> = {
  [aboutPrefix]: {
    subLinks: [
      { label: lang === 'zh' ? '關於我們' : 'Who We Are', href: aboutPrefix },
      { label: lang === 'zh' ? '信仰與願景' : 'Beliefs & Vision', href: `${aboutPrefix}/beliefs` },
    ],
    activePrefixes: [aboutPrefix],
  },
  // Grow dropdown — EN only (ZH has no Resources page, so 團契 is a direct link)
  ...(lang === 'en' ? {
    '/en/ministries': {
      subLinks: [
        { label: 'Ministries', href: '/en/ministries' },
        { label: 'Resources', href: '/en/resources' },
      ],
      activePrefixes: ['/en/ministries', '/en/resources'],
    },
  } : {}),
};
---

<header class="site-header">
  <div class="header-inner">
    <div class="header-left">
      <a href={logoHref} class="logo" aria-label={logoLabel}>
        <img src={logoSrc} alt={logoLabel} class="logo-img" width="220" height="44" />
      </a>
    </div>

    <div class="header-actions">
      <button
        class="hamburger"
        type="button"
        aria-expanded="false"
        aria-controls="nav-menu"
        aria-label="Toggle navigation menu"
      >
        <span class="hamburger-bar" aria-hidden="true"></span>
        <span class="hamburger-bar" aria-hidden="true"></span>
        <span class="hamburger-bar" aria-hidden="true"></span>
      </button>
    </div>

    <nav id="nav-menu" class="nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {navLinks.map((link) => {
          const dropdown = dropdowns[link.href];

          if (dropdown) {
            // Dropdown nav item (About, Grow)
            const dropdownActive = dropdown.activePrefixes.some(
              (prefix) => currentPath.startsWith(prefix)
            );
            return (
              <li class="nav-dropdown">
                <button
                  type="button"
                  class:list={['nav-link', 'nav-dropdown-trigger', { 'nav-link--active': dropdownActive }]}
                  aria-expanded="false"
                  aria-haspopup="true"
                >
                  {link.label}
                  <svg class="nav-dropdown-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                    <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <ul class="nav-dropdown-panel" role="list">
                  {dropdown.subLinks.map((sub) => {
                    const subActive = currentPath === sub.href || currentPath === sub.href + '/';
                    return (
                      <li>
                        <a
                          href={sub.href}
                          class:list={['nav-link', 'nav-dropdown-link', { 'nav-link--active': subActive }]}
                          aria-current={subActive ? 'page' : undefined}
                        >
                          {sub.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </li>
            );
          }

          // Regular nav item
          const isActive = currentPath === link.href
            || (link.href !== '/' && link.href !== '/zh' && link.href !== '/en/' && currentPath.startsWith(link.href));

          return (
            <li>
              <a
                href={link.href}
                class:list={['nav-link', { 'nav-link--active': isActive }]}
                aria-current={isActive ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
      <a href={langToggleHref} class="lang-toggle" aria-label={lang === 'zh' ? '切換至英文' : 'Switch to Chinese'}>
        {langToggleLabel}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-stone);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin-inline: auto;
    padding: var(--space-4) var(--space-6);
  }

  /* Logo + search grouped tight */
  .header-left {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .logo-img {
    height: 44px;
    width: auto;
  }

  /* Desktop nav */
  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .nav-list {
    display: flex;
    align-items: baseline;
    list-style: none;
    gap: var(--space-6);
  }
  .nav-link {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--base-800);
    text-decoration: none;
    padding: var(--space-1) 0;
    border-bottom: 2px solid transparent;
    transition: border-color var(--transition), color var(--transition);
  }
  .nav-link:hover {
    color: var(--primary-500);
    border-bottom-color: var(--primary-500);
  }
  .nav-link--active {
    color: var(--primary-600);
    border-bottom-color: var(--primary-500);
    font-weight: 600;
  }
  .nav-link:focus-visible {
    color: var(--primary-500);
    outline: 2px solid var(--color-focus);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  /* Dropdowns (About, Grow) */
  .nav-dropdown {
    position: relative;
  }
  .nav-dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    padding: var(--space-1) 0;
    margin: 0;
    /* Match .nav-link styles exactly — buttons don't inherit these */
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--base-800);
    line-height: normal;
  }
  .nav-dropdown-trigger.nav-link--active {
    color: var(--primary-600);
    border-bottom-color: var(--primary-500);
    font-weight: 600;
  }

  .nav-dropdown-chevron {
    transition: transform var(--transition);
  }
  @media (min-width: 768px) {
    .nav-dropdown:hover .nav-dropdown-chevron,
    .nav-dropdown:focus-within .nav-dropdown-chevron {
      transform: rotate(180deg);
    }
  }
  .nav-dropdown-panel {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 11rem;
    background: var(--color-bg);
    border: 1px solid var(--base-300);
    border-radius: var(--radius-lg);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    padding: var(--space-2);
    list-style: none;
    z-index: 200;
  }
  /* Invisible bridge between trigger and panel to prevent mouseout gap */
  .nav-dropdown-panel::before {
    content: '';
    position: absolute;
    top: -12px;
    left: 0;
    right: 0;
    height: 12px;
  }
  @media (min-width: 768px) {
    .nav-dropdown:hover .nav-dropdown-panel,
    .nav-dropdown:focus-within .nav-dropdown-panel {
      display: block;
    }
  }
  .nav-dropdown-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    border-bottom: none;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    color: var(--base-800); /* darker than --base-700 for WCAG AA contrast in dropdown panel */
  }
  .nav-dropdown-link:hover {
    background: var(--base-100);
    border-bottom-color: transparent;
  }

  /* Language toggle */
  .lang-toggle {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-ink);
    background: none;
    border: 1px solid var(--color-stone);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
    cursor: pointer;
    transition: background-color var(--transition), color var(--transition);
  }
  .lang-toggle:hover,
  .lang-toggle:focus-visible {
    background-color: var(--primary-500);
    color: var(--base-50);
    border-color: var(--primary-500);
  }
  .lang-toggle:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* Hamburger — hidden on desktop */
  .header-actions {
    display: none;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    z-index: 110;
  }
  .hamburger-bar {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-ink);
    border-radius: 1px;
    transition: transform var(--transition), opacity var(--transition);
  }
  .hamburger:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }
  .hamburger[aria-expanded='true'] .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger[aria-expanded='true'] .hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded='true'] .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile */
  @media (max-width: 767px) {
    .header-actions {
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }

    .nav {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(75vw, 20rem);
      flex-direction: column;
      align-items: flex-start;
      padding: var(--space-16) var(--space-6) var(--space-8);
      background-color: var(--color-bg);
      border-left: 1px solid var(--color-stone);
      box-shadow: -4px 0 24px rgba(0, 0, 0, 0.08);
      transform: translateX(100%);
      transition: transform var(--transition);
      z-index: 105;
    }
    .nav.is-open {
      transform: translateX(0);
    }

    .nav-list {
      flex-direction: column;
      gap: var(--space-4);
    }
    .nav-link {
      font-size: var(--text-base);
    }

    /* Mobile: About as label with indented sub-links */
    .nav-dropdown {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0;
    }
    .nav-dropdown-trigger {
      display: flex;
      pointer-events: none;
      font-size: var(--text-base);
      border-bottom: none;
    }
    .nav-dropdown-chevron {
      display: none;
    }
    .nav-dropdown-panel {
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
      position: static;
      transform: none;
      background: none;
      border: none;
      border-radius: 0;
      box-shadow: none;
      padding: var(--space-2) 0 0 var(--space-4);
      margin: 0;
      min-width: 0;
    }
    .nav-dropdown-panel::before {
      display: none;
    }
    .nav-link {
      border-bottom: none;
    }
    .nav-link:hover {
      border-bottom-color: transparent;
    }
    .nav-dropdown-link {
      padding: 0;
      border-radius: 0;
      font-size: var(--text-sm);
      color: var(--base-600);
    }
  }
</style>

<script>
  // Hamburger toggle
  const btn = document.querySelector('.hamburger') as HTMLButtonElement;
  const nav = document.querySelector('#nav-menu') as HTMLElement;

  if (btn && nav) {
    function openNav() {
      btn.setAttribute('aria-expanded', 'true');
      nav.classList.add('is-open');
      // Focus first link in nav for accessibility
      const firstLink = nav.querySelector('a, button') as HTMLElement | null;
      firstLink?.focus();
      document.addEventListener('focusin', trapFocus);
    }

    function closeNav() {
      btn.setAttribute('aria-expanded', 'false');
      nav.classList.remove('is-open');
      document.removeEventListener('focusin', trapFocus);
      btn.focus();
    }

    // Focus trap: keep focus inside nav while open
    function trapFocus(e: FocusEvent) {
      if (!nav.classList.contains('is-open')) return;
      if (!nav.contains(e.target as Node) && e.target !== btn) {
        const firstLink = nav.querySelector('a, button') as HTMLElement | null;
        firstLink?.focus();
      }
    }

    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      if (expanded) {
        closeNav();
      } else {
        openNav();
      }
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
        closeNav();
      }
    });
  }

</script>
