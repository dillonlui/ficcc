---
import { getNavLinks, type Lang } from '../lib/navigation';
import Search from 'astro-pagefind/components/Search';

interface Props {
  lang?: Lang;
  langToggleHref?: string;
}

const { lang = 'en', langToggleHref: langToggleHrefProp } = Astro.props;
const navLinks = getNavLinks(lang);
const logoHref = lang === 'zh' ? '/zh' : '/';
const logoText = lang === 'zh' ? '伊的家' : 'FICCC';
const logoLabel = lang === 'zh' ? '伊的家 — 首頁' : 'FICCC — Home';
const langToggleLabel = lang === 'zh' ? '中文 / EN' : 'EN / 中文';
const langToggleHref = langToggleHrefProp ?? (lang === 'zh' ? '/' : '/zh');
const currentPath = Astro.url.pathname;
const logoSrc = lang === 'zh' ? '/logo/logo-zh-light.svg' : '/logo/logo-en-light.svg';

// About dropdown sub-links
const aboutPrefix = lang === 'zh' ? '/zh/about' : '/about';
const aboutDropdown = [
  { label: lang === 'zh' ? '關於我們' : 'Who We Are', href: aboutPrefix },
  { label: lang === 'zh' ? '信仰與願景' : 'Beliefs & Vision', href: `${aboutPrefix}/beliefs` },
  { label: lang === 'zh' ? '來訪我們' : 'Visit Us', href: lang === 'zh' ? '/zh/sundays' : '/visit' },
];
const isAboutHref = (href: string) => href === '/about' || href === '/zh/about';
---

<header class="site-header">
  <div class="header-inner">
    <!-- Logo + search grouped together -->
    <div class="header-left">
      <a href={logoHref} class="logo" aria-label={logoLabel}>
        <img src={logoSrc} alt={logoLabel} class="logo-img" width="220" height="44" />
      </a>
      <div class="search-inline" id="search-inline">
        <button
          id="search-trigger"
          class="search-trigger"
          type="button"
          aria-label="Search"
          aria-expanded="false"
        >
          <svg width="18" height="18" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="8.5" cy="8.5" r="5.5" stroke="currentColor" stroke-width="2"/>
            <path d="M12.5 12.5L17 17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
        <div class="search-expand" id="search-expand" hidden>
          <Search id="search-widget" />
        </div>
      </div>
    </div>

    <div class="header-actions">
      <button
        class="hamburger"
        type="button"
        aria-expanded="false"
        aria-controls="nav-menu"
        aria-label="Toggle navigation menu"
      >
        <span class="hamburger-bar" aria-hidden="true"></span>
        <span class="hamburger-bar" aria-hidden="true"></span>
        <span class="hamburger-bar" aria-hidden="true"></span>
      </button>
    </div>

    <nav id="nav-menu" class="nav" aria-label="Main navigation">
      <ul class="nav-list" role="list">
        {navLinks.map((link) => {
          const isActive = currentPath === link.href
            || (link.href !== '/' && link.href !== '/zh' && currentPath.startsWith(link.href));

          if (isAboutHref(link.href)) {
            const aboutActive = currentPath.startsWith(aboutPrefix);
            return (
              <li class="nav-dropdown">
                <button
                  type="button"
                  class:list={['nav-link', 'nav-dropdown-trigger', { 'nav-link--active': aboutActive }]}
                  aria-expanded="false"
                  aria-haspopup="true"
                >
                  {link.label}
                  <svg class="nav-dropdown-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none" aria-hidden="true">
                    <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </button>
                <ul class="nav-dropdown-panel" role="list">
                  {aboutDropdown.map((sub) => {
                    const subActive = currentPath === sub.href || currentPath === sub.href + '/';
                    return (
                      <li>
                        <a
                          href={sub.href}
                          class:list={['nav-link', 'nav-dropdown-link', { 'nav-link--active': subActive }]}
                          aria-current={subActive ? 'page' : undefined}
                        >
                          {sub.label}
                        </a>
                      </li>
                    );
                  })}
                </ul>
              </li>
            );
          }

          return (
            <li>
              <a
                href={link.href}
                class:list={['nav-link', { 'nav-link--active': isActive }]}
                aria-current={isActive ? 'page' : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
      <a href={langToggleHref} class="lang-toggle" aria-label={lang === 'zh' ? '切換至英文' : 'Switch to Chinese'}>
        {langToggleLabel}
      </a>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-stone);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--max-width);
    margin-inline: auto;
    padding: var(--space-4) var(--space-6);
  }

  /* Logo + search grouped tight */
  .header-left {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }
  .logo-img {
    height: 44px;
    width: auto;
  }

  /* Inline expanding search */
  .search-inline {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--base-500);
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    transition: color var(--transition);
  }
  .search-trigger:hover,
  .search-trigger:focus-visible {
    color: var(--base-700);
  }
  .search-trigger:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* When open, hide the icon button */
  .search-inline.is-open .search-trigger {
    display: none;
  }

  .search-expand {
    display: none;
  }

  .search-expand.is-open {
    display: block;
    width: 16rem;
  }

  /* Theme Pagefind UI — compact inline, tight height */
  :global(#search-widget) {
    --pagefind-ui-scale: 0.65;
    --pagefind-ui-primary: var(--base-700);
    --pagefind-ui-text: var(--base-800);
    --pagefind-ui-background: var(--base-100);
    --pagefind-ui-border: var(--base-300);
    --pagefind-ui-tag: var(--base-200);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius-sm);
    --pagefind-ui-font: var(--font-body);
  }

  /* Tighten the input height */
  :global(#search-widget .pagefind-ui__search-input) {
    padding: 5px 8px 5px 28px !important;
    font-size: 13px !important;
    height: auto !important;
  }

  :global(#search-widget .pagefind-ui__search-clear) {
    padding: 2px 6px !important;
    right: 2px !important;
  }

  :global(#search-widget .pagefind-ui__form::before) {
    top: 7px !important;
    left: 8px !important;
    width: 14px !important;
    height: 14px !important;
  }

  /* Pagefind results dropdown — tighter padding */
  :global(#search-widget .pagefind-ui__results-area) {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    min-width: 22rem;
    background: var(--color-bg);
    border: 1px solid var(--base-300);
    border-radius: var(--radius-md);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    margin-top: var(--space-1);
    padding: var(--space-2);
    z-index: 200;
    max-height: 50vh;
    overflow-y: auto;
  }

  :global(#search-widget .pagefind-ui__result) {
    padding: var(--space-2) !important;
  }

  :global(#search-widget .pagefind-ui__result-title) {
    font-size: 13px !important;
  }

  :global(#search-widget .pagefind-ui__result-excerpt) {
    font-size: 12px !important;
    line-height: 1.4 !important;
  }

  /* Desktop nav */
  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }
  .nav-list {
    display: flex;
    list-style: none;
    gap: var(--space-6);
  }
  .nav-link {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--base-700);
    text-decoration: none;
    padding: var(--space-1) 0;
    border-bottom: 2px solid transparent;
    transition: border-color var(--transition), color var(--transition);
  }
  .nav-link:hover {
    color: var(--primary-500);
    border-bottom-color: var(--primary-500);
  }
  .nav-link--active {
    color: var(--primary-600);
    border-bottom-color: var(--primary-500);
    font-weight: 600;
  }
  .nav-link:focus-visible {
    color: var(--primary-500);
    outline: 2px solid var(--color-focus);
    outline-offset: 4px;
    border-radius: var(--radius-sm);
  }

  /* About dropdown */
  .nav-dropdown {
    position: relative;
  }
  .nav-dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    padding: var(--space-1) 0;
  }
  .nav-dropdown-chevron {
    transition: transform var(--transition);
  }
  .nav-dropdown:hover .nav-dropdown-chevron,
  .nav-dropdown:focus-within .nav-dropdown-chevron {
    transform: rotate(180deg);
  }
  .nav-dropdown-panel {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    min-width: 11rem;
    background: var(--color-bg);
    border: 1px solid var(--base-300);
    border-radius: var(--radius-lg);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
    padding: var(--space-2);
    list-style: none;
    z-index: 200;
  }
  /* Invisible bridge between trigger and panel to prevent mouseout gap */
  .nav-dropdown-panel::before {
    content: '';
    position: absolute;
    top: -12px;
    left: 0;
    right: 0;
    height: 12px;
  }
  .nav-dropdown:hover .nav-dropdown-panel,
  .nav-dropdown:focus-within .nav-dropdown-panel {
    display: block;
  }
  .nav-dropdown-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    border-bottom: none;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }
  .nav-dropdown-link:hover {
    background: var(--base-100);
    border-bottom-color: transparent;
  }

  /* Language toggle */
  .lang-toggle {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-ink);
    background: none;
    border: 1px solid var(--color-stone);
    border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3);
    cursor: pointer;
    transition: background-color var(--transition), color var(--transition);
  }
  .lang-toggle:hover,
  .lang-toggle:focus-visible {
    background-color: var(--primary-500);
    color: var(--base-50);
    border-color: var(--primary-500);
  }
  .lang-toggle:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* Hamburger — hidden on desktop */
  .header-actions {
    display: none;
  }

  .hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: var(--space-2);
    z-index: 110;
  }
  .hamburger-bar {
    display: block;
    width: 24px;
    height: 2px;
    background-color: var(--color-ink);
    border-radius: 1px;
    transition: transform var(--transition), opacity var(--transition);
  }
  .hamburger:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }
  .hamburger[aria-expanded='true'] .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger[aria-expanded='true'] .hamburger-bar:nth-child(2) {
    opacity: 0;
  }
  .hamburger[aria-expanded='true'] .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile */
  @media (max-width: 767px) {
    .header-actions {
      display: flex;
      align-items: center;
      gap: var(--space-2);
    }

    .nav {
      position: fixed;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(75vw, 20rem);
      flex-direction: column;
      align-items: flex-start;
      padding: var(--space-16) var(--space-6) var(--space-8);
      background-color: var(--color-bg);
      border-left: 1px solid var(--color-stone);
      box-shadow: -4px 0 24px rgba(0, 0, 0, 0.08);
      transform: translateX(100%);
      transition: transform var(--transition);
      z-index: 105;
    }
    .nav.is-open {
      transform: translateX(0);
    }

    .nav-list {
      flex-direction: column;
      gap: var(--space-4);
    }
    .nav-link {
      font-size: var(--text-base);
    }

    /* Mobile: flatten dropdown into normal list */
    .nav-dropdown-trigger {
      display: none;
    }
    .nav-dropdown-panel {
      display: contents;
      position: static;
      transform: none;
      background: none;
      border: none;
      border-radius: 0;
      box-shadow: none;
      padding: 0;
      margin: 0;
      min-width: 0;
    }
    .nav-dropdown-link {
      padding: var(--space-1) 0;
      border-radius: 0;
    }
    .nav-dropdown-link:hover {
      background: none;
    }
  }
</style>

<script>
  // Hamburger toggle
  const btn = document.querySelector('.hamburger') as HTMLButtonElement;
  const nav = document.querySelector('#nav-menu') as HTMLElement;

  if (btn && nav) {
    btn.addEventListener('click', () => {
      const expanded = btn.getAttribute('aria-expanded') === 'true';
      btn.setAttribute('aria-expanded', String(!expanded));
      nav.classList.toggle('is-open', !expanded);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && btn.getAttribute('aria-expanded') === 'true') {
        btn.setAttribute('aria-expanded', 'false');
        nav.classList.remove('is-open');
        btn.focus();
      }
    });
  }

  // Inline search toggle
  const searchTrigger = document.getElementById('search-trigger') as HTMLButtonElement;
  const searchExpand = document.getElementById('search-expand') as HTMLElement;
  const searchInline = document.getElementById('search-inline') as HTMLElement;

  if (searchTrigger && searchExpand && searchInline) {
    searchTrigger.addEventListener('click', () => {
      searchInline.classList.add('is-open');
      searchExpand.classList.add('is-open');
      searchTrigger.setAttribute('aria-expanded', 'true');
      requestAnimationFrame(() => {
        const input = searchExpand.querySelector<HTMLInputElement>('input[type="text"]');
        input?.focus();
      });
    });

    function closeSearch() {
      searchInline.classList.remove('is-open');
      searchExpand.classList.remove('is-open');
      searchTrigger.setAttribute('aria-expanded', 'false');
    }

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && searchInline.classList.contains('is-open')) {
        closeSearch();
        searchTrigger.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (searchInline.classList.contains('is-open')
        && !searchInline.contains(e.target as Node)) {
        closeSearch();
      }
    });
  }
</script>
