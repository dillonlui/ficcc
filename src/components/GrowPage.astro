---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from './Hero.astro';
import type { Lang } from '../lib/navigation';
import type { GrowPageContent } from '../lib/grow-pages';

interface Props {
  lang?: Lang;
  content: GrowPageContent;
}

const { lang = 'en', content } = Astro.props;
const sermonsHref = lang === 'zh' ? '/zh/sermons' : '/en/sermons';
const sermonsLabel = content.sermonsCtaText || (lang === 'zh' ? '瀏覽講道' : 'Watch Sermons');
const calloutHeading =
  content.sermonsCalloutHeading || (lang === 'zh' ? '聆聽我們正在學習的' : 'Hear what we are learning');
const calloutBody =
  content.sermonsCalloutBody ||
  (lang === 'zh'
    ? '瀏覽近期講道，聆聽我們每週日的教導信息。'
    : 'Catch up on recent messages or explore past teaching series from our Sunday gatherings.');
const calloutHref = content.sermonsCtaHref || sermonsHref;
---

<BaseLayout title={content.title} description={content.description} lang={lang}>
  <main id="main-content" data-pagefind-body>
    <Hero
      title={content.heroTitle}
      subtitle={content.heroSubtitle}
      backgroundImage={content.heroImage}
    />

    <section class="grow-listing" aria-label={content.listingHeading}>
      <div class="grow-listing__inner">
        <header class="grow-listing__header" data-reveal>
          <p class="grow-listing__eyebrow">{lang === 'zh' ? 'Grow' : 'Grow'}</p>
          <h2 class="grow-listing__heading">{content.listingHeading}</h2>
          <p class="grow-listing__intro">{content.intro}</p>
        </header>

        <div class="grow-grid" data-reveal>
          {content.groups.map((group) => (
            <article class="group-card">
              {group.image && (
                <div class="group-card__image">
                  <img src={group.image} alt={group.imageAlt || ''} loading="lazy" />
                </div>
              )}
              <div class="group-card__body">
                <h3 class="group-card__name">{group.name}</h3>
                {group.meetingTime && <p class="group-card__time">{group.meetingTime}</p>}
                <p class="group-card__desc">{group.description}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="sermons-callout" aria-label={sermonsLabel}>
      <div class="sermons-callout__tex" style="background-image: url('/images/textures/valentin-beauvais-4YrVF0gVdjk-unsplash.jpg')"></div>
      <div class="sermons-callout__inner">
        <h2 class="sermons-callout__heading" data-reveal>{calloutHeading}</h2>
        <p class="sermons-callout__body" data-reveal>{calloutBody}</p>
        <a href={calloutHref} class="sermons-callout__cta" data-reveal>
          {sermonsLabel}
          <svg class="sermons-callout__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .grow-listing {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
  }

  .grow-listing__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .grow-listing__header {
    max-width: 44rem;
    margin-inline: auto;
    text-align: center;
    margin-block-end: var(--space-10);
  }

  .grow-listing__eyebrow {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--color-terracotta-dark);
    margin-block-end: var(--space-2);
  }

  .grow-listing__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    margin-block-end: var(--space-4);
  }

  .grow-listing__intro {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    margin: 0;
  }

  .grow-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .group-card {
    background-color: var(--color-stone);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }

  .group-card__image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .group-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .group-card__body {
    padding: var(--space-6);
  }

  .group-card__name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin-block-end: var(--space-2);
  }

  .group-card__time {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-terracotta-dark);
    margin-block-end: var(--space-3);
  }

  .group-card__desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--base-800);
    margin: 0;
  }

  .sermons-callout {
    padding: var(--space-16) var(--space-6) calc(var(--space-16) + 2rem);
    background-color: var(--base-800);
    position: relative;
    overflow: hidden;
  }

  .sermons-callout__tex {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    pointer-events: none;
    opacity: 0.25;
    mix-blend-mode: soft-light;
    z-index: 0;
  }

  .sermons-callout__inner {
    max-width: 36rem;
    margin-inline: auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .sermons-callout__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--base-50);
    margin-block-end: var(--space-3);
  }

  .sermons-callout__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--base-300);
    margin-block-end: var(--space-6);
  }

  .sermons-callout__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .sermons-callout__cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sermons-callout__cta:hover {
    background-color: var(--primary-400);
    transform: translateY(-1px);
  }

  .sermons-callout__cta:hover .sermons-callout__cta-arrow {
    transform: translateX(4px);
  }

  .sermons-callout__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  @media (max-width: 1024px) {
    .grow-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .grow-listing {
      padding: var(--space-10) var(--space-4);
    }

    .grow-listing__heading {
      font-size: var(--text-2xl);
    }

    .grow-listing__intro,
    .sermons-callout__body {
      font-size: var(--text-base);
    }

    .grow-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }
</style>
