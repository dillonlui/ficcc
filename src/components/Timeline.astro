---
/**
 * Interactive scroll-filling timeline with era groupings.
 * Each era has a heading and a set of entries.
 */
interface TimelineEntry {
  year: string;
  description: string;
}

interface TimelineEra {
  title: string;
  entries: TimelineEntry[];
}

interface Props {
  eras: TimelineEra[];
  heading?: string;
}

const { eras, heading } = Astro.props;

// Build a flat list of items with type markers for rendering
type FlatItem = 
  | { type: 'era'; title: string }
  | { type: 'entry'; year: string; description: string; side: 'left' | 'right' };

const items: FlatItem[] = [];
let entryIndex = 0;
for (const era of eras) {
  items.push({ type: 'era', title: era.title });
  for (const entry of era.entries) {
    items.push({
      type: 'entry',
      year: entry.year,
      description: entry.description,
      side: entryIndex % 2 === 0 ? 'left' : 'right',
    });
    entryIndex++;
  }
}
---

<section class="timeline-section" aria-label={heading || 'Timeline'}>
  {heading && <h2 class="timeline-section__heading">{heading}</h2>}
  <div class="timeline" id="interactive-timeline">
    <div class="timeline__track">
      <div class="timeline__bg-line"></div>
      <div class="timeline__fill-line" id="timeline-fill"></div>
    </div>

    {items.map((item) => {
      if (item.type === 'era') {
        return (
          <div class="timeline__era">
            <div class="timeline__era-node"><div class="timeline__era-diamond"></div></div>
            <h3 class="timeline__era-title">{item.title}</h3>
          </div>
        );
      }
      const entry = item;
      return (
        <div class={`timeline__entry timeline__entry--${entry.side}`}>
          {entry.side === 'left' ? (
            <Fragment>
              <div class="timeline__card">
                <span class="timeline__year">{entry.year}</span>
                <p class="timeline__desc">{entry.description}</p>
              </div>
              <div class="timeline__node"><div class="timeline__dot"></div></div>
              <div class="timeline__empty"></div>
            </Fragment>
          ) : (
            <Fragment>
              <div class="timeline__empty"></div>
              <div class="timeline__node"><div class="timeline__dot"></div></div>
              <div class="timeline__card">
                <span class="timeline__year">{entry.year}</span>
                <p class="timeline__desc">{entry.description}</p>
              </div>
            </Fragment>
          )}
        </div>
      );
    })}
  </div>
</section>

<style>
  .timeline-section {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
    overflow-x: hidden;
  }

  .timeline-section__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    text-align: center;
    margin-block-end: var(--space-10);
  }

  .timeline {
    position: relative;
    max-width: 48rem;
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 48px 1fr;
    row-gap: var(--space-6);
  }

  /* Vertical track */
  .timeline__track {
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 3px;
    transform: translateX(-50%);
  }

  .timeline__bg-line {
    position: absolute;
    inset: 0;
    background: var(--base-300);
    border-radius: 2px;
  }

  .timeline__fill-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--primary-400);
    border-radius: 2px;
    transform-origin: top center;
    transform: scaleY(0);
    transition: transform 0.1s linear;
  }

  /* Era header — spans full width, centered on the track */
  .timeline__era {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-4) 0;
    margin-top: var(--space-4);
    position: relative;
    z-index: 2;
  }

  .timeline__era:first-child,
  .timeline__track + .timeline__era {
    margin-top: 0;
    padding-top: 0;
  }

  .timeline__era-node {
    display: none; /* hidden — era title is enough */
  }

  .timeline__era-title {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--primary-600);
    background: var(--color-bg);
    padding: var(--space-1) var(--space-4);
    border: 1.5px solid var(--primary-300);
    border-radius: var(--radius-pill);
    white-space: nowrap;
    position: relative;
    z-index: 2;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .timeline__era.is-active .timeline__era-title {
    opacity: 1;
    transform: translateY(0);
  }

  /* Entry — subgrid */
  .timeline__entry {
    display: grid;
    grid-template-columns: subgrid;
    grid-column: 1 / -1;
    align-items: center;
  }

  @supports not (grid-template-columns: subgrid) {
    .timeline__entry {
      display: grid;
      grid-template-columns: 1fr 48px 1fr;
      grid-column: 1 / -1;
    }
  }

  .timeline__entry--left .timeline__card {
    grid-column: 1;
    text-align: right;
    padding-right: var(--space-6);
  }
  .timeline__entry--left .timeline__node { grid-column: 2; }
  .timeline__entry--left .timeline__empty { grid-column: 3; }

  .timeline__entry--right .timeline__empty { grid-column: 1; }
  .timeline__entry--right .timeline__node { grid-column: 2; }
  .timeline__entry--right .timeline__card {
    grid-column: 3;
    text-align: left;
    padding-left: var(--space-6);
  }

  /* Node dot */
  .timeline__node {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 2;
  }

  .timeline__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--base-300);
    border: 3px solid var(--color-bg);
    box-shadow: 0 0 0 2px var(--base-300);
    transition: background 0.4s ease, box-shadow 0.4s ease;
  }

  .timeline__dot.is-filled {
    background: var(--primary-500);
    box-shadow: 0 0 0 2px var(--primary-400);
  }

  /* Card */
  .timeline__card {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .timeline__entry.is-active .timeline__card {
    opacity: 1;
    transform: translateY(0);
  }

  .timeline__year {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--primary-500);
    margin-block-end: var(--space-1);
  }

  .timeline__desc {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--base-700);
  }

  /* Mobile: single column, track on left */
  @media (max-width: 767px) {
    .timeline {
      grid-template-columns: 28px 1fr;
    }

    .timeline__track {
      left: 13px;
      transform: none;
    }

    .timeline__entry {
      grid-template-columns: 28px 1fr;
      grid-auto-flow: dense;
      align-items: start;
    }

    .timeline__node {
      padding-top: 6px;
    }

    .timeline__empty { display: none; }

    .timeline__entry--left .timeline__card,
    .timeline__entry--right .timeline__card {
      grid-column: 2;
      text-align: left;
      padding-left: var(--space-4);
      padding-right: 0;
    }

    .timeline__entry--left .timeline__node,
    .timeline__entry--right .timeline__node {
      grid-column: 1;
    }

    .timeline__era {
      grid-column: 1 / -1;
      justify-content: flex-start;
      padding-left: var(--space-8);
      max-width: 100%;
    }

    .timeline__era-title {
      font-size: var(--text-sm);
      white-space: normal;
      text-align: center;
    }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .timeline__fill-line {
      transform: scaleY(1);
      transition: none;
    }
    .timeline__card {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .timeline__era-title {
      opacity: 1;
      transform: none;
      transition: none;
    }
    .timeline__dot {
      background: var(--primary-500);
      box-shadow: 0 0 0 2px var(--primary-400);
      transition: none;
    }
  }
</style>

<script>
  function initTimeline() {
    const timeline = document.getElementById('interactive-timeline');
    const fill = document.getElementById('timeline-fill');
    const track = timeline?.querySelector('.timeline__track') as HTMLElement | null;
    if (!timeline || !fill || !track) return;

    const dots = Array.from(timeline.querySelectorAll('.timeline__dot')) as HTMLElement[];
    const entries = Array.from(timeline.querySelectorAll('.timeline__entry')) as HTMLElement[];
    const eras = Array.from(timeline.querySelectorAll('.timeline__era')) as HTMLElement[];
    if (!dots.length) return;

    // Position the track line to span from first dot to last dot
    function updateTrackBounds() {
      const timelineRect = timeline!.getBoundingClientRect();
      const firstDot = dots[0].getBoundingClientRect();
      const lastDot = dots[dots.length - 1].getBoundingClientRect();

      const topOffset = firstDot.top + firstDot.height / 2 - timelineRect.top;
      const bottomOffset = lastDot.top + lastDot.height / 2 - timelineRect.top;

      track!.style.top = `${topOffset}px`;
      track!.style.bottom = `${timelineRect.height - bottomOffset}px`;
    }

    function updateFill() {
      updateTrackBounds();

      const trackRect = track!.getBoundingClientRect();
      const viewMid = window.innerHeight * 0.6;
      const trackTop = trackRect.top;
      const trackHeight = trackRect.height;

      // If user has scrolled to near the bottom of the page, force full progress
      // so the last node always activates even if it can't reach the 60% trigger
      const scrolledToBottom =
        window.innerHeight + window.scrollY >= document.body.scrollHeight - 50;

      let progress: number;
      if (scrolledToBottom) {
        progress = 1;
      } else if (trackTop >= viewMid) {
        progress = 0;
      } else if (trackTop + trackHeight <= viewMid) {
        progress = 1;
      } else {
        progress = (viewMid - trackTop) / trackHeight;
      }
      progress = Math.min(1, Math.max(0, progress));
      fill!.style.transform = `scaleY(${progress})`;

      // Fill dots and eras when the line reaches them
      const fillY = trackRect.top + trackHeight * progress;
      dots.forEach((dot, i) => {
        const dotRect = dot.getBoundingClientRect();
        const dotCenter = dotRect.top + dotRect.height / 2;
        const entry = entries[i];
        if (progress > 0 && fillY >= dotCenter) {
          dot.classList.add('is-filled');
          entry?.classList.add('is-active');
        }
      });
      eras.forEach((era) => {
        const eraRect = era.getBoundingClientRect();
        const eraCenter = eraRect.top + eraRect.height / 2;
        if (eraCenter <= viewMid) {
          era.classList.add('is-active');
        }
      });

      // Stop loop once all dots are activated
      const allFilled = dots.every((dot) => dot.classList.contains('is-filled'));
      const allErasActive = eras.every((era) => era.classList.contains('is-active'));
      if (allFilled && allErasActive) return;

      requestAnimationFrame(updateFill);
    }
    // Double-rAF ensures the browser paints the initial hidden state
    // before we start adding is-active classes, so transitions play.
    requestAnimationFrame(() => requestAnimationFrame(updateFill));
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTimeline);
  } else {
    initTimeline();
  }
</script>
