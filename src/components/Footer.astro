---
/**
 * Site footer — church info, nav links, copyright.
 * Uses CSS custom properties only.
 */
import { getFooterNav, getServiceTimes, getChurchName, type Lang } from '../lib/navigation';
import { getSiteSettings } from '../lib/sanity';

interface Props {
  lang?: Lang;
}

const { lang = 'en' } = Astro.props;
const currentYear = new Date().getFullYear();
const footerNav = getFooterNav(lang);
const serviceTimes = getServiceTimes(lang);
const churchName = getChurchName(lang);

let siteSettings: Awaited<ReturnType<typeof getSiteSettings>> = null;
try {
  siteSettings = await getSiteSettings(lang);
} catch {}

// Use CMS service times if available, otherwise fall back to navigation.ts
const resolvedServiceTimes = siteSettings?.serviceTimes?.length
  ? { heading: serviceTimes.heading, items: siteSettings.serviceTimes.map((st: any) => ({ label: `${st.label}: ${st.time}` })) }
  : serviceTimes;

// Use CMS contact info if available
const resolvedAddress = siteSettings?.address || '429 Mitchell Street';
const resolvedCity = siteSettings?.city || 'Ithaca, NY 14850';
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- Church identity -->
    <div class="footer-col footer-identity">
      <a href={lang === 'zh' ? '/zh' : '/en/'} class="footer-logo-link" aria-label="Home">
        <img src="/logo/logo-bilingual-dark.svg" alt="FICCC" class="footer-logo" width="280" height="52" />
      </a>
      <address class="footer-address">
        {resolvedAddress}<br />
        {resolvedCity}
      </address>
    </div>

    <!-- Service times -->
    <div class="footer-col footer-services">
      <h2 class="footer-heading">{resolvedServiceTimes.heading}</h2>
      <ul class="footer-list" role="list">
        {resolvedServiceTimes.items.map((item) => (
          <li>{item.label}</li>
        ))}
      </ul>
    </div>

    <!-- Navigation -->
    <nav class="footer-col footer-nav" aria-label="Footer navigation">
      <h2 class="footer-heading">Links</h2>
      <ul class="footer-list" role="list">
        {footerNav.map((link) => (
          <li><a href={link.href} class="footer-link">{link.label}</a></li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="footer-bottom">
    <p class="footer-cornell">This organization is a registered student organization of Cornell University. With a founding principle of "... any person ... any study," <a href="https://hr.cornell.edu/about/workplace-rights/equal-education-and-employment" target="_blank" rel="noopener noreferrer">Cornell is an equal opportunity employer</a>.</p>
    <p>&copy; {currentYear} {churchName}. All rights reserved.</p>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg-dark);
    color: var(--color-bg);
    margin-top: -2rem;
    position: relative;
    z-index: 6;
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: var(--space-8);
    max-width: var(--max-width);
    margin-inline: auto;
    padding: var(--space-12) var(--space-6) var(--space-8);
  }

  .footer-logo-link {
    display: block;
    margin-block-end: var(--space-4);
  }
  .footer-logo {
    height: 52px;
    width: auto;
  }
  .footer-address {
    font-style: normal;
    font-size: var(--text-sm);
    color: var(--color-stone);
    line-height: var(--leading-relaxed);
  }

  .footer-heading {
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-bg);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-block-end: var(--space-4);
  }

  .footer-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-stone);
  }

  .footer-link {
    color: var(--color-stone);
    text-decoration: none;
    transition: color var(--transition);
  }
  .footer-link:hover,
  .footer-link:focus-visible {
    color: var(--color-terracotta);
  }
  .footer-link:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
    border-radius: var(--radius-sm);
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    max-width: var(--max-width);
    margin-inline: auto;
    padding: var(--space-6) var(--space-6);
    font-size: var(--text-xs);
    color: var(--color-stone);
    text-align: center;
  }

  .footer-cornell {
    font-size: var(--text-xs);
    color: var(--base-500);
    line-height: var(--leading-relaxed);
    margin-block-end: var(--space-2);
  }
  .footer-cornell a {
    color: var(--base-400);
    text-decoration: none;
  }
  .footer-cornell a:hover {
    text-decoration: underline;
  }
</style>
