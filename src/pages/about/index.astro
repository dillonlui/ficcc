---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Timeline from '../../components/Timeline.astro';
import { getAboutPage, portableTextToHtml, urlForImage } from '../../lib/sanity';
import { buildOrganizationJsonLd } from '../../lib/structured-data';

const title = 'Who We Are | FICCC';
const description =
  'Learn about First Ithaca Chinese Christian Church, our history, mission, and community.';

// ---------- CMS data (graceful fallback when Sanity is unreachable) ----------
let aboutPage: Awaited<ReturnType<typeof getAboutPage>> = null;

try {
  aboutPage = await getAboutPage('en');
} catch {
  // Sanity unreachable — continue with fallbacks
}

// ---------- Fallback defaults ----------
const fallbackHeading = 'Who We Are';
const fallbackBody = `
<p>First Ithaca Chinese Christian Church (FICCC) was founded in 1968 by a small group of Chinese graduate students and scholars at Cornell University who longed for a Christ-centered community where they could worship in their heart language while welcoming the broader Ithaca community.</p>
<p>Over the decades the church has grown from that small group into a congregation that bridges Chinese heritage and American life. We gather every Sunday at 429 Mitchell Street for worship, teaching, and fellowship in English and Mandarin, serving students, families, and neighbors throughout the Finger Lakes region.</p>
<p>Our mission is to glorify God by making disciples of Jesus Christ who love God wholeheartedly, love one another sacrificially, and reach out to the world with the Gospel. We believe the local church is God's primary instrument for advancing His kingdom, and we are committed to equipping every member for a life of faithful service.</p>
<p>If you've lived in Ithaca for years, just arrived as a visiting scholar, or are a student far from home, there is a place for you at FICCC. Come as you are.</p>
`.trim();

// ---------- Resolved data (CMS ▸ fallback) ----------
const heading = aboutPage?.whoWeAreHeading || fallbackHeading;
const bodyHtml = aboutPage?.whoWeAreBody?.length
  ? portableTextToHtml(aboutPage.whoWeAreBody)
  : fallbackBody;
const imageUrl = aboutPage?.whoWeAreImage
  ? urlForImage(aboutPage.whoWeAreImage, { width: 800 })
  : '/images/hero/cornell-arts-quad.webp';
---

<BaseLayout title={title} description={description} jsonLd={buildOrganizationJsonLd()}>
  <main id="main-content" data-pagefind-body class="about">
    <section class="about__hero" aria-label="Who We Are">
      <div class="about__split">
        <div class="about__text">
          <h1 class="about__heading" data-reveal>{heading}</h1>
          <div class="about__body" data-reveal set:html={bodyHtml} />
        </div>
        {imageUrl && (
          <div class="about__image-col">
            <img
              class="about__image"
              src={imageUrl}
              alt="Cornell University Arts Quad with Goldwin Smith Hall, Baker Lab, and Olin Library"
              loading="eager"
            />
          </div>
        )}
      </div>
    </section>

    <!-- Snapshots -->
    <section class="snapshots snapshots--tinted" aria-label="Snapshots of God's Faithfulness">
      <div class="snapshots__inner">
        <h2 class="snapshots__heading" data-reveal>Snapshots of God's Faithfulness</h2>
        <div class="snapshots__grid" data-reveal-stagger>
          <div class="snapshots__item" data-reveal>
            <span class="snapshots__accent">40+ years in Ithaca</span>
            <p class="snapshots__body">Worshiping, studying Scripture, and sharing life together at Cornell and throughout Ithaca.</p>
          </div>
          <div class="snapshots__item" data-reveal>
            <span class="snapshots__accent">A church family of ~100</span>
            <p class="snapshots__body">Students, scholars, and longtime Ithaca residents walking with Christ together.</p>
          </div>
          <div class="snapshots__item" data-reveal>
            <span class="snapshots__accent">Countless alumni</span>
            <p class="snapshots__body">Now serving in churches and communities across the US, Canada, and Asia - carrying what they learned here into the rest of their lives.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Pastors -->
    <section class="pastors" aria-label="Our Pastors">
      <div class="pastors__inner">
        <h2 class="pastors__heading" data-reveal>Our Pastors</h2>
        <div class="pastors__grid" data-reveal-stagger>
          <div class="pastors__card" data-reveal>
            <div class="pastors__photo">
              <img src="/images/church/zhida-zhu.webp" alt="Pastor Zhida Zhu" loading="lazy" width="400" height="533" />
            </div>
            <div class="pastors__info">
              <h3 class="pastors__name">Min. Zhida Zhu (朱志達)</h3>
              <p class="pastors__role">Pastor of English Ministry</p>
              <p class="pastors__bio">
                Zhida grew up in an immigrant church in Houston, Texas. After declaring himself
                an atheist in high school, God powerfully changed his heart through 3 key
                individuals after college, and he gave his life to Christ. He served as a
                mechanical engineer for 6 years before answering the call to full-time ministry.
                Zhida is married to Ngun, whom he met at Dallas Theological Seminary.
              </p>
            </div>
          </div>
          <div class="pastors__card" data-reveal>
            <div class="pastors__photo pastors__photo--placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/>
                <path d="M4 21v-1a6 6 0 0112 0v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="pastors__info">
              <h3 class="pastors__name">Min. Simon Ye (葉劍峰)</h3>
              <p class="pastors__role">Pastor of Chinese Ministry</p>
              <p class="pastors__bio">
                Pastor Simon leads the Chinese-speaking congregation, shepherding
                families, fellowship groups, and community ministries.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Timeline heading="Our Story" eras={[
      {
        title: 'Beginnings: Student Fellowship to Church (1968-1988)',
        entries: [
          { year: '1968', description: 'Chinese graduate students and scholars at Cornell University start a Bible study group.' },
          { year: '1974', description: 'The Bible study grows into a regular Sunday worship gathering.' },
          { year: '1983', description: 'The fellowship formalizes its organization and begins systematic discipleship training.' },
          { year: '1986', description: 'First Ithaca Chinese Christian Church is officially established as an independent congregation.' },
          { year: '1988', description: 'The church purchases a house at 1462 Slaterville Road and converts it into a church building.' },
        ],
      },
      {
        title: 'Putting Down Roots in Ithaca (1988-2000)',
        entries: [
          { year: '1993', description: 'The church purchases 429 Mitchell Street as its permanent home.' },
          { year: '1996', description: 'Pastoral staff is established; elders and deacons are appointed.' },
          { year: '1997', description: 'FICCC joins the Evangelical Free Church of America (EFCA).' },
          { year: '1997', description: 'Pastor Xin-Dao Xu begins serving as lead pastor.' },
          { year: '1998-1999', description: 'Youth fellowship and youth Sunday school are launched; a missions committee is formed and missions policy established.' },
          { year: '1999-2000', description: 'Additional ministry houses (such as the House of Joy) are purchased to support growing ministry.' },
        ],
      },
      {
        title: 'Growing English Ministry & Next Generation (2000-2010)',
        entries: [
          { year: '2000', description: 'English ministry launches, with the first English worship service on August 20.' },
          { year: '2001', description: 'FICCC partners with China Evangelical Seminary to offer annual theology extension courses in Ithaca.' },
          { year: '2002', description: 'The first church-wide retreat is held.' },
          { year: '2007', description: 'The church acquires additional property (House of Peace) behind the main building to support ministry needs.' },
          { year: '2008', description: 'Pastor Paul begins serving as English ministry pastor.' },
          { year: '2009', description: 'FICCC begins sending summer mission teams to lead VBS in Brooklyn, New York.' },
        ],
      },
      {
        title: 'Continuing the Mission (2010-Present)',
        entries: [
          { year: 'Today', description: 'FICCC continues to disciple students, scholars, and families; send members into full-time ministry; and invest in both Chinese- and English-speaking congregations in Ithaca and beyond.' },
        ],
      },
    ]} />

    <!-- Beliefs callout -->
    <section class="beliefs-callout" aria-label="Beliefs and Vision">
      <div class="beliefs-callout__inner">
        <h2 class="beliefs-callout__heading" data-reveal>What do we believe?</h2>
        <p class="beliefs-callout__body" data-reveal>
          The Bible shapes everything we do. See what we hold to and where we're headed.
        </p>
        <a href="/about/beliefs" class="beliefs-callout__cta" data-reveal>
          Beliefs &amp; Vision
          <svg class="beliefs-callout__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .about {
    padding-block: 0;
  }

  /* Exilic-style split: text left, image fills right column */
  .about__hero {
    background-color: var(--color-bg);
  }

  .about__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: var(--max-width);
    margin-inline: auto;
    min-height: 32rem;
  }

  .about__text {
    padding: var(--space-16) var(--space-6) var(--space-16) var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about__heading {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    color: var(--color-ink);
    margin-block-end: var(--space-8);
  }

  .about__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    max-width: 36rem;
  }

  .about__body :global(p) {
    margin-block-end: var(--space-4);
  }

  .about__body :global(p:last-child) {
    margin-block-end: 0;
  }

  .about__body :global(a) {
    color: var(--primary-500);
    text-decoration: underline;
  }

  /* Image column — rounded container, stretches to match text height */
  .about__image-col {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    align-self: stretch;
    margin: var(--space-16) var(--space-6) var(--space-16) 0;
  }

  .about__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  /* ---------- Snapshots ---------- */
  .snapshots {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
  }

  .snapshots--tinted {
    background-color: var(--color-stone);
  }

  /* ---------- Pastors ---------- */
  .pastors {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
  }

  .pastors__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .pastors__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    text-align: center;
    margin-block-end: var(--space-10);
  }

  .pastors__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
    max-width: 56rem;
    margin-inline: auto;
  }

  .pastors__card {
    background-color: var(--color-stone);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .pastors__photo {
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .pastors__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pastors__photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--base-300);
    color: var(--base-500);
  }

  .pastors__info {
    width: 100%;
  }

  .pastors__name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin-block-end: var(--space-2);
    text-align: center;
  }

  .pastors__role {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-body);
    margin-block-end: var(--space-3);
    text-align: center;
  }

  .pastors__bio {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
  }

  .snapshots__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .snapshots__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    text-align: center;
    margin-block-end: var(--space-10);
  }

  .snapshots__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .snapshots__item {
    text-align: center;
    padding: var(--space-6);
  }

  .snapshots__accent {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--primary-500);
    margin-block-end: var(--space-2);
  }

  .snapshots__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--base-700);
  }

  /* ---------- Beliefs Callout ---------- */
  .beliefs-callout {
    padding: var(--space-16) var(--space-6) calc(var(--space-16) + 2rem);
    background-color: var(--base-800);
  }

  .beliefs-callout__inner {
    max-width: 36rem;
    margin-inline: auto;
    text-align: center;
  }

  .beliefs-callout__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--base-50);
    margin-block-end: var(--space-3);
  }

  .beliefs-callout__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--base-300);
    margin-block-end: var(--space-6);
  }

  .beliefs-callout__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .beliefs-callout__cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .beliefs-callout__cta:hover {
    background-color: var(--primary-400);
    transform: translateY(-1px);
  }

  .beliefs-callout__cta:hover .beliefs-callout__cta-arrow {
    transform: translateX(4px);
  }

  .beliefs-callout__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  @media (max-width: 767px) {
    .about__split {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .about__image-col {
      order: -1;
      height: 16rem;
      position: relative;
      border-radius: var(--radius-lg);
      margin: var(--space-6) var(--space-4) 0;
      min-height: auto;
    }

    .about__text {
      padding: var(--space-8) var(--space-4);
    }

    .about__heading {
      font-size: var(--text-3xl);
    }

    .about__body {
      font-size: var(--text-base);
    }

    .snapshots__grid {
      grid-template-columns: 1fr;
    }

    .pastors__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
