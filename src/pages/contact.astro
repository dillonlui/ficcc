---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';

const title = 'Contact | First Ithaca Chinese Christian Church';
const description =
  'Get in touch with First Ithaca Chinese Christian Church. Send us a message — we would love to hear from you.';
---

<BaseLayout title={title} description={description}>
  <main id="main-content" data-pagefind-body>
    <Hero
      title="Contact Us"
      subtitle="We'd love to hear from you"
      backgroundImage="/images/hero/friends-golden.webp"
    />

    <section class="contact-section" aria-label="Contact">
      <div class="contact-section__inner">
        <div class="contact-layout">
          <!-- Contact form -->
          <div class="contact-form-wrap" data-reveal>
            <h2 class="contact-form-wrap__heading">Send Us a Message</h2>
            <p class="contact-form-wrap__intro">
              Questions about our church, ministries, prayer requests, or anything else. We're here for you.
            </p>
            <ContactForm />
          </div>

          <!-- Church info sidebar -->
          <div class="contact-info" role="region" aria-label="Church contact information" data-reveal>
            <h2 class="contact-info__heading">Church Information</h2>

            <div class="contact-info__block">
              <h3 class="contact-info__label">Address</h3>
              <address class="contact-info__value">
                First Ithaca Chinese Christian Church<br />
                429 Mitchell Street<br />
                Ithaca, NY 14850
              </address>
            </div>

            <div class="contact-info__block">
              <h3 class="contact-info__label">Sunday Services</h3>
              <p class="contact-info__value">
                English Worship: 9:45 AM<br />
                Discipleship Groups: 11:00 AM<br />
                Chinese Worship: 11:15 AM
              </p>
            </div>

            <div class="contact-info__block">
              <h3 class="contact-info__label">Email</h3>
              <p class="contact-info__value">
                <a href="mailto:info@ficcc.org" class="contact-info__link">info@ficcc.org</a>
              </p>
            </div>

            <div class="contact-info__block">
              <h3 class="contact-info__label">Phone</h3>
              <p class="contact-info__value">
                <a href="tel:+16072731223" class="contact-info__link">(607) 273-1223</a>
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<!-- Turnstile loaded in explicit mode -->
<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js?render=explicit" async defer></script>

<script is:inline>
(function () {
  function initTurnstile() {
    if (typeof turnstile === 'undefined') return;
    var container = document.querySelector('.cf-turnstile');
    if (!container) return;
    var siteKey = container.getAttribute('data-sitekey') || '';
    if (!siteKey) return;
    while (container.firstChild) container.removeChild(container.firstChild);
    turnstile.render(container, { sitekey: siteKey, theme: 'light' });
  }

  if (typeof turnstile !== 'undefined') {
    initTurnstile();
  } else {
    var attempts = 0;
    var interval = setInterval(function () {
      attempts++;
      if (typeof turnstile !== 'undefined') {
        clearInterval(interval);
        initTurnstile();
      } else if (attempts > 50) {
        clearInterval(interval);
      }
    }, 100);
  }
})();
</script>

<style>
  .contact-section {
    padding: var(--space-16) var(--space-6) calc(var(--space-16) + 2rem);
    background-color: var(--color-bg);
  }

  .contact-section__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  /* Layout: form + sidebar */
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 22rem;
    gap: var(--space-16);
    align-items: start;
  }

  /* Form wrapper */
  .contact-form-wrap__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--color-ink);
    margin-block-end: var(--space-2);
  }

  .contact-form-wrap__intro {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    margin-block-end: var(--space-8);
  }

  /* ---------- Church info sidebar ---------- */

  .contact-info {
    background-color: var(--base-100);
    border-radius: var(--radius-md);
    padding: var(--space-8);
  }

  .contact-info__heading {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--color-ink);
    margin: 0 0 var(--space-6) 0;
  }

  .contact-info__block {
    margin-bottom: var(--space-6);
  }

  .contact-info__block:last-child {
    margin-bottom: 0;
  }

  .contact-info__label {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 var(--space-1) 0;
  }

  .contact-info__value {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-body);
    line-height: var(--leading-relaxed);
    margin: 0;
    font-style: normal;
  }

  .contact-info__link {
    color: var(--primary-500);
    text-decoration: none;
    transition: color var(--transition);
  }

  .contact-info__link:hover {
    color: var(--primary-400);
    text-decoration: underline;
  }

  .contact-info__link:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
    border-radius: 2px;
  }

  /* ---------- Responsive ---------- */

  @media (max-width: 768px) {
    .contact-layout {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .contact-section {
      padding: var(--space-10) var(--space-4) calc(var(--space-10) + 2rem);
    }
  }
</style>
