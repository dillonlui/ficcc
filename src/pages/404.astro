---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found | 頁面未找到" description="The page you're looking for doesn't exist.">
  <main id="main-content" data-pagefind-ignore="all" class="error-page">
    <img src="/logo/icon-light.svg" alt="" class="error-icon" width="96" height="96" />
    <h1>404</h1>
    <p class="error-en">Sorry, the page you're looking for doesn't exist or has been moved.</p>
    <p class="error-zh" lang="zh">抱歉，您要找的頁面不存在或已被移動。</p>
    <div class="error-links">
      <a href="/en/" class="home-link">English Home</a>
      <a href="/zh/" class="home-link">中文首頁</a>
    </div>
  </main>
</BaseLayout>

<style>
  .error-page {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: 60vh;
    padding: var(--space-8) var(--space-4);
  }

  .error-icon {
    margin-bottom: var(--space-6);
    opacity: 0.6;
  }

  h1 {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    color: var(--color-ink);
    margin-bottom: var(--space-4);
    line-height: var(--leading-tight);
  }

  p {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-body);
    max-width: 480px;
    line-height: var(--leading-normal);
  }

  .error-en {
    margin-bottom: var(--space-2);
  }

  .error-zh {
    margin-bottom: var(--space-8);
  }

  .error-links {
    display: flex;
    gap: var(--space-4);
  }

  .home-link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .home-link:hover {
    background-color: var(--primary-600);
    transform: translateY(-1px);
  }

  .home-link:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }
</style>
