---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getHomePage, getSermons, getEvents, urlForImage, urlForFile, portableTextToHtml, getSiteSettings } from '../../lib/sanity';
import { buildChurchJsonLd, buildWebSiteJsonLd } from '../../lib/structured-data';

const title = '伊的家華人基督教會 | First Ithaca Chinese Christian Church';
const description =
  '紐約伊薩卡的華人基督教會。每週日上午9:45崇拜，地址：429 Mitchell Street。歡迎大學生、家庭及社區鄰舍。';

let homePage: Awaited<ReturnType<typeof getHomePage>> = null;
let sermons: Awaited<ReturnType<typeof getSermons>> = [];
let events: Awaited<ReturnType<typeof getEvents>> = [];

let siteSettings: Awaited<ReturnType<typeof getSiteSettings>> = null;

try {
  [homePage, sermons, events] = await Promise.all([
    getHomePage('zh'),
    getSermons('zh'),
    getEvents('zh'),
  ]);
} catch {}

try {
  siteSettings = await getSiteSettings('zh');
} catch {}

if (homePage?.isVisible === false) return Astro.redirect('/404');

const serviceTimeItems = siteSettings?.serviceTimes || [
  { label: '華語崇拜', time: '11:15 AM' },
  { label: '門徒小組', time: '11:00 AM' },
];
const churchAddress = siteSettings?.address || '429 Mitchell Street';
const churchCity = siteSettings?.city || 'Ithaca, NY 14850';

const defaultHeroImage = '/images/hero/ficcc-hero-poster.jpg';
const defaultHeroVideo = '/videos/ficcc-hero.mp4';
const heroImage = homePage?.heroImage
  ? urlForImage(homePage.heroImage, { width: 1600 })
  : defaultHeroImage;
const heroFallbackImage = homePage?.heroFallbackImage
  ? urlForImage(homePage.heroFallbackImage, { width: 1600 })
  : heroImage;
const heroVideo =
  homePage?.heroMediaType === 'video'
    ? urlForFile(homePage.heroVideo)
    : homePage?.heroMediaType === 'image'
      ? ''
      : defaultHeroVideo;
const heroTitle = homePage?.heroTitle || '歡迎回家';
const heroSubtitle =
  homePage?.heroSubtitle ||
  '在神的話語中更深扎根，在以福音為中心的群體中成長，在日常門訓中被建立。';

const fallbackSections = [
  {
    label: '認識我們',
    heading: '在FICCC更深扎根',
    bodyHtml: '<p>無論你是伊薩卡的長期居民、訪問學者，還是遠離家鄉的學生，這裡都有你的位置。</p>',
    image: '/images/church/bbq-2025-group-wide.webp',
    imageAlt: '伊的家教會大家庭戶外合影',
    ctaText: '進一步了解我們',
    ctaHref: '/zh/about',
    layout: 'default',
    tinted: false,
  },
  {
    label: '主日體驗',
    heading: '主日早晨',
    bodyHtml: '<p>上午11:15我們一起唱詩、聯聖經講道、守主餐。上午11:00進入門徒小組，進行討論和禱告。之後我們一起吃午餐-通常是中餐。</p>',
    image: '/images/church/bbq-2025-outdoor-worship.webp',
    imageAlt: '伊的家弟兄姊妹在戶外一同唱詩',
    ctaText: '規劃你的首次來訪',
    ctaHref: '/zh/sundays',
    layout: 'reversed',
    tinted: true,
  },
  {
    label: '群體生活',
    heading: '尋找群體',
    bodyHtml: '<p>查經班、團契小組、短宣、共餐。我們鼓勵每個人參與服事-在教會中、在校園裡、在伊薩卡社區裡。</p>',
    image: '/images/church/epp-2025-diverse-community.webp',
    imageAlt: '不同世代的伊的家弟兄姊妹合影',
    ctaText: '探索事工',
    ctaHref: '/zh/grow/chinese',
    layout: 'default',
    tinted: false,
  },
  {
    label: '講道',
    heading: '觀看講道',
    bodyHtml: '<p>回顧近期講道或探索過往的教導系列。我們的講道每週上傳至YouTube。</p>',
    image: '/images/church/epp-2025-worship-guitar.webp',
    imageAlt: '伊的家弟兄姊妹在戶外以吉他伴奏唱詩',
    ctaText: '瀏覽講道',
    ctaHref: '/zh/sermons',
    layout: 'reversed',
    tinted: true,
  },
];

const homeSections = homePage?.sections?.length
  ? homePage.sections.map((section, index) => ({
      label: section.heading,
      heading: section.heading,
      bodyHtml: portableTextToHtml(section.body),
      image: section.image ? urlForImage(section.image, { width: 900 }) : fallbackSections[index]?.image,
      imageAlt: section.imageAlt || fallbackSections[index]?.imageAlt || '',
      ctaText: section.ctaText,
      ctaHref: section.ctaHref,
      layout: section.layout || fallbackSections[index]?.layout || 'default',
      tinted: section.tinted ?? fallbackSections[index]?.tinted ?? false,
    }))
  : fallbackSections;

const bannerHeading = homePage?.bannerHeading || '連結文化與世代';
const bannerBodyHtml = homePage?.bannerBody?.length
  ? portableTextToHtml(homePage.bannerBody)
  : '<p>我們珍惜華人傳統，同時建立一個歡迎學生、家庭和各背景鄰舍的教會家園。</p>';
const bannerImage = homePage?.bannerImage
  ? urlForImage(homePage.bannerImage, { width: 1600 })
  : '/images/church/bbq-2025-community-singing.webp';
const bannerImageAlt = homePage?.bannerImageAlt || '多元社區成員在一起';
const bannerCtaText = homePage?.bannerCtaText || '與我們聯繫';
const bannerCtaHref = homePage?.bannerCtaHref || '/zh/contact';

const siteUrl = (Astro.site ?? new URL('https://ficcc.org')).href;
const homeJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [buildChurchJsonLd(), buildWebSiteJsonLd(siteUrl)],
};
---

<BaseLayout title={title} description={description} lang="zh" jsonLd={homeJsonLd} ogType="website">
  <main id="main-content" data-pagefind-body>

    <!-- ============ HERO — tall, editorial, people-first ============ -->
    <section class="hero-home">
      {heroVideo ? (
        <video
          class="hero-home__media"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          poster={heroFallbackImage}
          aria-hidden="true"
        >
          <source src={heroVideo} type="video/mp4" />
        </video>
      ) : (
        <img
          class="hero-home__media"
          src={heroImage}
          alt=""
          fetchpriority="high"
          loading="eager"
          decoding="async"
        />
      )}
      <div class="hero-home__overlay">
        <div class="hero-home__content">
          <h1 class="hero-home__title" data-reveal>{heroTitle}</h1>
          <p class="hero-home__subtitle" data-reveal>{heroSubtitle}</p>
          <!-- Service info — two-column: times left, location right -->
          <div class="hero-info" data-reveal>
            <div class="hero-info__times">
              <div class="hero-info__item">
                <span class="hero-info__label">
                  <svg class="hero-info__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2L3 9v11a2 2 0 002 2h4v-7h6v7h4a2 2 0 002-2V9l-9-7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 2v4h6V2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  {serviceTimeItems[0]?.label}
                </span>
                <span class="hero-info__value">{serviceTimeItems[0]?.time}</span>
              </div>
              <div class="hero-info__item">
                <span class="hero-info__label">
                  <svg class="hero-info__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  {serviceTimeItems[1]?.label}
                </span>
                <span class="hero-info__value">{serviceTimeItems[1]?.time}</span>
              </div>
            </div>
            <div class="hero-info__divider"></div>
            <div class="hero-info__location">
              <div class="hero-info__item">
                <span class="hero-info__label">
                  <svg class="hero-info__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
                  地址
                </span>
                <span class="hero-info__value">{churchAddress}<br/>{churchCity}</span>
              </div>
            </div>
          </div>

          <a class="hero-home__cta" href="/zh/sundays" data-reveal>
            規劃你的來訪
            <svg class="hero-home__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
      {heroVideo && (
        <button
          class="hero-home__media-toggle"
          type="button"
          data-hero-video-toggle
          data-label-pause="暫停背景影片"
          data-label-play="播放背景影片"
          aria-label="暫停背景影片"
        >
          <svg class="hero-home__toggle-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path data-hero-video-toggle-icon d="M8 5v14M16 5v14" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" />
          </svg>
        </button>
      )}
    </section>

    {homeSections.map((section) => (
      <section
        class:list={['split', { 'split--reversed': section.layout === 'reversed', 'split--tinted': section.tinted, 'split--textured': section.tinted }]}
        aria-label={section.label}
      >
        {section.tinted && <div class="split__tex" style="background-image: url('/images/textures/kiwihug-qv05FvdE26k-unsplash.jpg')"></div>}
        <div class="split__inner">
          {section.image && (
            <div class="split__media" data-reveal>
              <img src={section.image} alt={section.imageAlt} loading="lazy" />
            </div>
          )}
          <div class="split__content" data-reveal>
            <h2 class="split__heading">{section.heading}</h2>
            {section.bodyHtml && <div class="split__body" set:html={section.bodyHtml} />}
            {section.ctaText && section.ctaHref && (
              <a href={section.ctaHref} class="split__link">{section.ctaText} <svg class="link-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
            )}
          </div>
        </div>
      </section>
    ))}

    <!-- ============ SECTION 5: 連結文化與世代 banner ============ -->
    <section class="banner" aria-label="連結文化">
      <img
        class="banner__img"
        src={bannerImage}
        alt={bannerImageAlt}
        loading="lazy"
      />
      <div class="banner__overlay">
        <div class="banner__content" data-reveal>
          <h2 class="banner__heading">{bannerHeading}</h2>
          <div class="banner__body" set:html={bannerBodyHtml} />
          <a href={bannerCtaHref} class="banner__cta">{bannerCtaText}</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const videoToggle = document.querySelector<HTMLButtonElement>('[data-hero-video-toggle]');
  const heroVideo = document.querySelector<HTMLVideoElement>('.hero-home video');

  if (videoToggle && heroVideo) {
    const iconPath = videoToggle.querySelector<SVGPathElement>('[data-hero-video-toggle-icon]');
    const pauseLabel = videoToggle.dataset.labelPause || '暫停背景影片';
    const playLabel = videoToggle.dataset.labelPlay || '播放背景影片';
    const pausePath = 'M8 5v14M16 5v14';
    const playPath = 'M8 5v14l11-7-11-7z';

    const syncVideoToggle = () => {
      const isPaused = heroVideo.paused;
      videoToggle.setAttribute('aria-label', isPaused ? playLabel : pauseLabel);
      iconPath?.setAttribute('d', isPaused ? playPath : pausePath);
      if (isPaused) {
        iconPath?.setAttribute('fill', 'currentColor');
        iconPath?.removeAttribute('stroke');
        iconPath?.removeAttribute('stroke-width');
        iconPath?.removeAttribute('stroke-linecap');
      } else {
        iconPath?.setAttribute('fill', 'none');
        iconPath?.setAttribute('stroke', 'currentColor');
        iconPath?.setAttribute('stroke-width', '2.25');
        iconPath?.setAttribute('stroke-linecap', 'round');
      }
    };

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      heroVideo.pause();
    }

    videoToggle.addEventListener('click', () => {
      if (heroVideo.paused) {
        void heroVideo.play();
      } else {
        heroVideo.pause();
      }
      syncVideoToggle();
    });

    heroVideo.addEventListener('play', syncVideoToggle);
    heroVideo.addEventListener('pause', syncVideoToggle);
    syncVideoToggle();
  }
</script>

<style>
  /* ================================================================
     HERO — tall, editorial, people-first
     ================================================================ */
  .hero-home {
    position: relative;
    min-height: 85vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background-color: var(--color-bg-dark);
  }

  .hero-home__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }

  .hero-home__overlay {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      to bottom,
      rgba(26, 58, 44, 0.25) 0%,
      rgba(26, 58, 44, 0.55) 60%,
      rgba(26, 58, 44, 0.75) 100%
    );
    padding: var(--space-16) var(--space-6);
  }

  .hero-home__content {
    text-align: center;
    max-width: 42rem;
  }

  .hero-home__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.1;
    color: var(--color-bg);
    margin-block-end: var(--space-4);
  }

  .hero-home__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--color-stone);
    max-width: 32rem;
    margin-inline: auto;
    margin-block-end: var(--space-8);
  }

  .hero-home__cta {
    margin-top: var(--space-8);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .hero-home__cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-home__cta:hover {
    background-color: var(--primary-600);
    transform: translateY(-1px);
  }

  .hero-home__cta:hover .hero-home__cta-arrow {
    transform: translateX(4px);
  }

  .hero-home__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .hero-home__media-toggle {
    position: absolute;
    right: var(--space-6);
    bottom: var(--space-6);
    z-index: 2;
    width: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--base-50);
    background: rgba(26, 58, 44, 0.72);
    border: 1px solid rgba(255, 255, 255, 0.28);
    border-radius: 999px;
    box-shadow: var(--shadow-md);
    cursor: pointer;
    transition:
      background-color var(--transition),
      border-color var(--transition),
      transform var(--transition);
  }

  .hero-home__media-toggle:hover {
    background: rgba(26, 58, 44, 0.9);
    border-color: rgba(255, 255, 255, 0.42);
    transform: translateY(-1px);
  }

  .hero-home__media-toggle:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 3px;
  }

  .hero-home__media-toggle svg {
    flex-shrink: 0;
  }

  /* ================================================================
     HERO INFO — two-column: times | location
     ================================================================ */
  .hero-info {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-top: var(--space-10);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-xl);
    padding: var(--space-5) var(--space-6);
    text-align: left;
    max-width: 32rem;
  }

  .hero-info__times {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-info__item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-info__divider {
    width: 1px;
    align-self: stretch;
    background: rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
  }

  .hero-info__location {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-info__icon {
    flex-shrink: 0;
    color: currentColor;
    vertical-align: -2px;
  }

  .hero-info__label {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.55);
  }

  .hero-info__value {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    padding-left: 19px; /* align with label text (14px icon + 5px gap) */
  }

  /* ================================================================
     SPLIT SECTIONS — image + text, alternating
     ================================================================ */
  .split {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
    position: relative;
    overflow: hidden;
  }

  .split--textured .split__tex {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    pointer-events: none;
    opacity: 0.35;
    z-index: 0;
  }

  .split--textured .split__inner {
    position: relative;
    z-index: 1;
  }

  .split--tinted {
    background-color: var(--color-stone);
  }

  .split__inner {
    max-width: var(--max-width);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .split--reversed .split__inner {
    direction: rtl;
  }

  .split--reversed .split__inner > * {
    direction: ltr;
  }

  .split__media {
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .split__media img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .split__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    margin-block-end: var(--space-4);
  }

  .split__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    margin-block-end: var(--space-6);
  }

  .split__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--primary-500);
    text-decoration: none;
    padding: var(--space-3) var(--space-6);
    border: 2px solid var(--primary-500);
    border-radius: 100vw;
    transition: background-color var(--transition), color var(--transition);
  }

  .split__link .link-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .split__link:hover {
    background-color: var(--primary-500);
    color: var(--base-50);
  }

  .split__link:hover .link-arrow {
    transform: translateX(4px);
  }

  .split__link:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* ================================================================
     BANNER — full-width closing section
     ================================================================ */
  .banner {
    position: relative;
    min-height: 32rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .banner__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .banner__overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 58, 44, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-16) var(--space-6);
  }

  .banner__content {
    max-width: 40rem;
    text-align: center;
  }

  .banner__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-bg);
    margin-block-end: var(--space-4);
  }

  .banner__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-stone);
    margin-block-end: var(--space-8);
  }

  .banner__cta {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-bg);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
