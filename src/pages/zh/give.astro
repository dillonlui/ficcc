---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

const title = '奉獻 | 伊薩卡華人基督教會';
const description =
  '透過您的慷慨奉獻，支持伊薩卡華人基督教會的事工。';
---

<BaseLayout title={title} description={description} lang="zh">
  <main id="main-content" data-pagefind-body>
    <Hero
      title="奉獻"
      subtitle="您的慷慨帶來改變"
      backgroundImage="/images/textures/adam-vradenburg-_gu7E90QChU-unsplash.jpg"
    />

    <!-- Why We Give -->
    <section class="give-section" aria-label="為什麼奉獻">
      <div class="give-section__inner">
        <h2 class="section-heading" data-reveal>為什麼奉獻</h2>
        <div class="give-prose" data-reveal>
          <p>
            奉獻是敬拜和信靠的行動。當我們慷慨奉獻時，我們參與了神的事工：
            支持教會群體、關懷有需要的人、傳揚耶穌基督的福音。
          </p>
          <blockquote class="give-verse">
            <p>
              「各人要隨本心所酌定的，不要作難，不要勉強，因為捐得樂意的人是神所喜愛的。」
            </p>
            <cite>哥林多後書 9:7</cite>
          </blockquote>
          <p>
            無論您是第一次奉獻還是多年來一直支持我們教會，每一份奉獻
            都幫助我們繼續服事伊薩卡及周邊社區。感謝您的忠心。
          </p>
        </div>
      </div>
    </section>

    <!-- Ways to Give -->
    <section class="give-section give-section--alt" aria-label="奉獻方式">
      <div class="give-section__inner">
        <h2 class="section-heading" data-reveal>奉獻方式</h2>
        <div class="give-methods" data-reveal-stagger>

          <!-- Online via PayPal -->
          <div class="give-method" data-reveal>
            <div class="give-method__icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            </div>
            <h3 class="give-method__title">網上奉獻 / PayPal</h3>
            <p class="give-method__desc">
              透過 PayPal 安全地進行網上奉獻。您可以使用 PayPal 帳戶、
              借記卡或信用卡。
            </p>
            <a
              class="give-method__link"
              href="https://www.paypal.com/donate/?cmd=_donations&amp;business=ficccfinance1%40gmail.com&amp;item_name=First+Ithaca+Chinese+Christian+Church+Offering&amp;currency_code=USD&amp;source=url"
              target="_blank"
              rel="noopener noreferrer"
            >
              透過 PayPal 奉獻
              <svg class="cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>

          <!-- By Check -->
          <div class="give-method" data-reveal>
            <div class="give-method__icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3 class="give-method__title">支票奉獻</h3>
            <p class="give-method__desc">
              支票抬頭請寫 <strong>First Ithaca Chinese Christian
              Church</strong>，並郵寄至：
            </p>
            <address class="give-method__address">
              First Ithaca Chinese Christian Church<br />
              429 Mitchell Street<br />
              Ithaca, NY 14850
            </address>
          </div>

          <!-- In Person -->
          <div class="give-method" data-reveal>
            <div class="give-method__icon" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
            </div>
            <h3 class="give-method__title">現場奉獻</h3>
            <p class="give-method__desc">
              主日崇拜時備有奉獻信封。您可以將奉獻放入聖殿內的奉獻箱中。
            </p>
            <p class="give-method__note">
              每週日上午 11:15 · 429 Mitchell Street
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Questions -->
    <section class="give-questions" aria-label="關於奉獻的問題">
      <div class="give-questions__tex" style="background-image: url('/images/textures/valentin-beauvais-4YrVF0gVdjk-unsplash.jpg')"></div>
      <div class="give-questions__inner">
        <h2 class="give-questions__heading" data-reveal>有問題嗎？</h2>
        <p class="give-questions__body" data-reveal>
          如果您對奉獻、免稅收據或其他支持教會的方式有任何疑問，請隨時與我們聯繫。
        </p>
        <a href="/zh/contact" class="give-questions__cta" data-reveal>
          聯繫我們
          <svg class="cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    text-align: center;
    margin-block-end: var(--space-10);
  }

  .give-section {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
  }

  .give-section--alt {
    background-color: var(--color-stone);
  }

  .give-section__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  /* ---------- Prose ---------- */
  .give-prose {
    max-width: 52rem;
    margin-inline: auto;
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
  }

  .give-prose p {
    margin-block-end: var(--space-4);
  }

  .give-prose p:last-child {
    margin-block-end: 0;
  }

  .give-prose a {
    color: var(--primary-500);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .give-prose a:hover {
    color: var(--primary-600);
  }

  /* ---------- Verse ---------- */
  .give-verse {
    border-inline-start: 3px solid var(--primary-400);
    padding: var(--space-6) var(--space-8);
    margin: var(--space-8) 0;
    background-color: var(--primary-50);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .give-verse p {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-style: italic;
    line-height: var(--leading-relaxed);
    color: var(--color-ink);
    margin-block-end: var(--space-2);
  }

  .give-verse cite {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    font-weight: 600;
    color: var(--primary-600);
  }

  /* ---------- Methods Grid ---------- */
  .give-methods {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-8);
  }

  .give-method {
    background-color: var(--color-bg);
    border-radius: var(--radius-xl);
    border: 1px solid var(--base-300);
    padding: var(--space-8) var(--space-6);
    text-align: center;
  }

  .give-method__icon {
    color: var(--primary-500);
    margin-block-end: var(--space-4);
    display: flex;
    justify-content: center;
  }

  .give-method__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin-block-end: var(--space-3);
  }

  .give-method__desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    margin-block-end: var(--space-4);
  }

  .give-method__desc strong {
    color: var(--color-ink);
  }

  .give-method__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .give-method__link .cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .give-method__link:hover {
    background-color: var(--primary-600);
    transform: translateY(-1px);
  }

  .give-method__link:hover .cta-arrow {
    transform: translateX(4px);
  }

  .give-method__link:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .give-method__address {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    line-height: var(--leading-relaxed);
    color: var(--color-body);
  }

  .give-method__note {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--primary-500);
    font-weight: 600;
  }

  /* ---------- Questions Section — painted canvas ---------- */
  .give-questions {
    position: relative;
    overflow: hidden;
    background-color: var(--base-800);
    padding: var(--space-16) var(--space-6) calc(var(--space-16) + 2rem);
  }

  .give-questions__tex {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    pointer-events: none;
    opacity: 0.25;
    mix-blend-mode: soft-light;
    z-index: 0;
  }

  .give-questions__inner {
    max-width: 42rem;
    margin-inline: auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .give-questions__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--base-50);
    margin-block-end: var(--space-3);
  }

  .give-questions__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--base-200);
    margin-block-end: var(--space-6);
  }

  .give-questions__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .give-questions__cta .cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .give-questions__cta:hover {
    background-color: var(--primary-400);
    transform: translateY(-1px);
  }

  .give-questions__cta:hover .cta-arrow {
    transform: translateX(4px);
  }

  .give-questions__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 768px) {
    .section-heading {
      font-size: var(--text-2xl);
    }

    .give-prose {
      font-size: var(--text-base);
    }

    .give-methods {
      grid-template-columns: 1fr;
    }
  }
</style>
