---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Timeline from '../../../components/Timeline.astro';
import { getAboutPage, portableTextToHtml, urlForImage } from '../../../lib/sanity';
import { buildOrganizationJsonLd } from '../../../lib/structured-data';

const title = '關於我們 | 伊的家華人基督教會';
const description =
  '了解伊的家華人基督教會的歷史、使命和群體。';

let aboutPage: Awaited<ReturnType<typeof getAboutPage>> = null;

try {
  aboutPage = await getAboutPage('zh');
} catch {}

const fallbackHeading = '我們是誰';
const fallbackBody = `
<p>伊的家華人基督教會（FICCC）於1968年由一群在康奈爾大學就讀的華人研究生和學者創立，他們渴望建立一個以基督為中心的群體，在其中用自己的心靈語言敬拜，同時歡迎伊薩卡的各界朋友。</p>
<p>幾十年來，教會從這個小小的團契成長為一個橋接華人傳統與美國文化的會眾。我們每週日在429 Mitchell Street聚會，以中英雙語進行敬拜、教導和團契，服事學生、家庭和整個手指湖地區的鄰舍。</p>
<p>我們的使命是榮耀神，造就愛神、愛人、向世界傳福音的門徒。我們相信地方教會是神推進祂國度的首要工具，我們致力於裝備每位會眾過忠心服事的生活。</p>
<p>無論你是伊薩卡的長期居民、剛到的訪問學者，還是遠離家鄉的學生，這裡都有你的位置。歡迎你的到來。</p>
`.trim();

const heading = aboutPage?.whoWeAreHeading || fallbackHeading;
const bodyHtml = aboutPage?.whoWeAreBody?.length
  ? portableTextToHtml(aboutPage.whoWeAreBody)
  : fallbackBody;
const imageUrl = aboutPage?.whoWeAreImage
  ? urlForImage(aboutPage.whoWeAreImage, { width: 800 })
  : '/images/hero/cornell-arts-quad.webp';
---

<BaseLayout title={title} description={description} lang="zh" jsonLd={buildOrganizationJsonLd()}>
  <main id="main-content" data-pagefind-body class="about">
    <section class="about__hero" aria-label="我們是誰">
      <div class="about__split">
        <div class="about__text">
          <h1 class="about__heading" data-reveal>{heading}</h1>
          <div class="about__body" data-reveal set:html={bodyHtml} />
        </div>
        {imageUrl && (
          <div class="about__image-col">
            <img
              class="about__image"
              src={imageUrl}
              alt="康奈爾大學藝術廣場"
              loading="eager"
            />
          </div>
        )}
      </div>
    </section>

    <!-- Snapshots -->
    <section class="snapshots snapshots--tinted snapshots--textured" aria-label="神的信實">
      <div class="snapshots__tex" style="background-image: url('/images/textures/kiwihug-qv05FvdE26k-unsplash.jpg')"></div>
      <div class="snapshots__inner">
        <h2 class="snapshots__heading" data-reveal>神的信實</h2>
        <div class="snapshots__grid" data-reveal-stagger>
          <div class="snapshots__item" data-reveal>
            <span class="snapshots__accent">扎根伊薩卡40餘年</span>
            <p class="snapshots__body">在康奈爾和整個伊薩卡社區一同敬拜、研讀聖經、分享生命。</p>
          </div>
          <div class="snapshots__item" data-reveal>
            <span class="snapshots__accent">約100人的教會家庭</span>
            <p class="snapshots__body">學生、學者和伊薩卡長期居民一同與基督同行。</p>
          </div>
          <div class="snapshots__item" data-reveal>
            <span class="snapshots__accent">無數的校友</span>
            <p class="snapshots__body">現在服事於美國、加拿大和亞洲的教會和社區，將在這裡學到的帶入他們一生的服事中。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Pastors -->
    <section class="pastors" aria-label="我們的牧者">
      <div class="pastors__inner">
        <h2 class="pastors__heading" data-reveal>我們的牧者</h2>
        <div class="pastors__grid" data-reveal-stagger>
          <div class="pastors__card" data-reveal>
            <div class="pastors__photo pastors__photo--placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <circle cx="12" cy="8" r="4" stroke="currentColor" stroke-width="1.5"/>
                <path d="M4 21v-1a6 6 0 0112 0v1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <div class="pastors__info">
              <h3 class="pastors__name">葉劍峰傳道 (Simon Ye)</h3>
              <p class="pastors__role">中文部牧者</p>
              <p class="pastors__bio">
                葉傳道帶領中文會眾，牧養家庭、團契小組和社區事工。
              </p>
            </div>
          </div>
          <div class="pastors__card" data-reveal>
            <div class="pastors__photo">
              <img src="/images/church/zhida-zhu.webp" alt="朱志達傳道" loading="lazy" width="400" height="533" />
            </div>
            <div class="pastors__info">
              <h3 class="pastors__name">朱志達傳道 (Zhida Zhu)</h3>
              <p class="pastors__role">英文部牧者</p>
              <p class="pastors__bio">
                志達在德州休士頓的一間華人移民教會長大。高中時自稱無神論者，
                但大學畢業後，神透過三位關鍵人物大大改變了他的心，他將生命獻給了基督。
                他曾擔任機械工程師六年，之後回應全職事工的呼召。
                志達與在達拉斯神學院認識的妻子Ngun結婚。
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <Timeline heading="教會歷史" eras={[
      {
        title: '起源：從查經班到教會 (1968-1988)',
        entries: [
          { year: '1968', description: '康奈爾大學華人學生查經班成立。' },
          { year: '1974', description: '查經班發展為主日崇拜聚會。' },
          { year: '1983', description: '華人查經班正式組織化，開始有系統的門徒訓練。' },
          { year: '1986', description: '正式成立伊的家華人基督教會，成為獨立堂會。' },
          { year: '1988', description: '購買在1462 Slaterville Rd的房子，並轉換為教堂使用的建築。' },
        ],
      },
      {
        title: '在伊薩卡扎根 (1988-2000)',
        entries: [
          { year: '1993', description: '購置 429 Mitchell Street 現址作為永久會堂。' },
          { year: '1996', description: '成立教牧同工會，任命長老和執事。' },
          { year: '1997', description: '加入播道會（EFCA），以確保未來的教義純正。' },
          { year: '1997', description: '徐心道牧師開始擔任教會的牧師。' },
          { year: '1998-1999', description: '成立青少年團契和青少年主日學；制定宣教政策並成立宣教委員會。' },
          { year: '1999-2000', description: '購買 House of Joy 等事工房屋，支持不斷增長的事工。' },
        ],
      },
      {
        title: '英語事工與下一代 (2000-2010)',
        entries: [
          { year: '2000', description: '增加英語部，並於8月20日舉行第一次英語崇拜。' },
          { year: '2001', description: '與中國福音神學院合作，每年在伊薩卡開設神學延伸制課程。' },
          { year: '2002', description: '舉行第一次教會退修會。' },
          { year: '2007', description: '購買House of Peace（230 Ridgedale，教會後方的建築）。' },
          { year: '2008', description: '艾保羅牧師開始擔任英文部牧師。' },
          { year: '2009', description: '開始派遣短宣隊，每年夏天在紐約布魯克林市帶領暑期聖經學校。' },
        ],
      },
      {
        title: '繼續使命 (2010-至今)',
        entries: [
          { year: '今天', description: 'FICCC繼續門訓學生、學者和家庭；差派會員進入全職事工；並投資於伊薩卡及其他地方的中文和英文會眾。' },
        ],
      },
    ]} />

    <!-- Beliefs callout -->
    <section class="beliefs-callout" aria-label="我們的信仰">
      <div class="beliefs-callout__tex" style="background-image: url('/images/textures/valentin-beauvais-4YrVF0gVdjk-unsplash.jpg')"></div>
      <div class="beliefs-callout__inner">
        <h2 class="beliefs-callout__heading" data-reveal>我們相信什麼？</h2>
        <p class="beliefs-callout__body" data-reveal>
          聖經塑造了我們所做的一切。了解我們的信仰立場和異象方向。
        </p>
        <a href="/zh/about/beliefs" class="beliefs-callout__cta" data-reveal>
          信仰與願景
          <svg class="beliefs-callout__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .about {
    padding-block: 0;
  }

  .about__hero {
    background-color: var(--color-bg);
  }

  .about__split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    max-width: var(--max-width);
    margin-inline: auto;
    min-height: 32rem;
  }

  .about__text {
    padding: var(--space-16) var(--space-6);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about__heading {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    color: var(--color-ink);
    margin-block-end: var(--space-8);
  }

  .about__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    max-width: 36rem;
  }

  .about__body :global(p) {
    margin-block-end: var(--space-4);
  }

  .about__body :global(p:last-child) {
    margin-block-end: 0;
  }

  .about__body :global(a) {
    color: var(--primary-500);
    text-decoration: underline;
  }

  .about__image-col {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    align-self: stretch;
    margin: var(--space-16) var(--space-6) var(--space-16) 0;
  }

  .about__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  /* ---------- Snapshots ---------- */
  .snapshots {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
    position: relative;
    overflow: hidden;
  }

  .snapshots--tinted {
    background-color: var(--color-stone);
  }

  .snapshots--textured .snapshots__tex {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    pointer-events: none;
    opacity: 0.35;
    z-index: 0;
  }

  .snapshots--textured .snapshots__inner {
    position: relative;
    z-index: 1;
  }

  .snapshots__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .snapshots__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    text-align: center;
    margin-block-end: var(--space-10);
  }

  .snapshots__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .snapshots__item {
    text-align: center;
    padding: var(--space-6);
  }

  .snapshots__accent {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--primary-500);
    margin-block-end: var(--space-2);
  }

  .snapshots__body {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--base-700);
  }

  /* ---------- Pastors ---------- */
  .pastors {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
  }

  .pastors__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .pastors__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    text-align: center;
    margin-block-end: var(--space-10);
  }

  .pastors__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-8);
    max-width: 56rem;
    margin-inline: auto;
  }

  .pastors__card {
    background-color: var(--color-stone);
    border-radius: var(--radius-xl);
    padding: var(--space-8);
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
  }

  .pastors__photo {
    width: 8rem;
    height: 8rem;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
  }

  .pastors__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pastors__photo--placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--base-300);
    color: var(--base-500);
  }

  .pastors__info {
    width: 100%;
  }

  .pastors__name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin-block-end: var(--space-2);
    text-align: center;
  }

  .pastors__role {
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-body);
    margin-block-end: var(--space-3);
    text-align: center;
  }

  .pastors__bio {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
  }

  /* ---------- Beliefs Callout ---------- */
  .beliefs-callout {
    padding: var(--space-16) var(--space-6) calc(var(--space-16) + 2rem);
    background-color: var(--base-800);
    position: relative;
    overflow: hidden;
  }

  .beliefs-callout__tex {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    pointer-events: none;
    opacity: 0.25;
    mix-blend-mode: soft-light;
    z-index: 0;
  }

  .beliefs-callout__inner {
    max-width: 36rem;
    margin-inline: auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .beliefs-callout__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--base-50);
    margin-block-end: var(--space-3);
  }

  .beliefs-callout__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--base-300);
    margin-block-end: var(--space-6);
  }

  .beliefs-callout__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .beliefs-callout__cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .beliefs-callout__cta:hover {
    background-color: var(--primary-400);
    transform: translateY(-1px);
  }

  .beliefs-callout__cta:hover .beliefs-callout__cta-arrow {
    transform: translateX(4px);
  }

  .beliefs-callout__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  @media (max-width: 767px) {
    .about__split {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .about__image-col {
      order: -1;
      height: 16rem;
      position: relative;
      border-radius: var(--radius-lg);
      margin: var(--space-6) var(--space-4) 0;
      min-height: auto;
    }

    .about__text {
      padding: var(--space-8) var(--space-4);
    }

    .about__heading {
      font-size: var(--text-3xl);
    }

    .about__body {
      font-size: var(--text-base);
    }

    .snapshots__grid {
      grid-template-columns: 1fr;
    }

    .pastors__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
