---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Accordion from '../../../components/Accordion.astro';
import { getAboutPage, portableTextToHtml } from '../../../lib/sanity';

const title = '我們的信仰 | 伊的家華人基督教會';
const description =
  '伊的家華人基督教會的核心信仰，美國播道會（EFCA）十一條信仰宣言。';

// ---------- CMS data (graceful fallback when Sanity is unreachable) ----------
let aboutPage: Awaited<ReturnType<typeof getAboutPage>> = null;

try {
  aboutPage = await getAboutPage('zh');
} catch {
  // Sanity unreachable — continue with fallbacks
}

// ---------- EFCA 11-point Statement of Faith in Chinese ----------
const fallbackBeliefs = [
  {
    title: '一、神',
    content:
      '<p>我們相信獨一的真神，祂是永恆存在的三個位格：聖父、聖子、聖靈。每一位都完全是神，各有位格之分，卻在本質和目的上合而為一。祂是萬物的創造者、維持者和統治者。</p>',
  },
  {
    title: '二、聖經',
    content:
      '<p>我們相信聖經（舊約和新約）是神所默示的話語，在原稿中完全無誤。聖經是信仰和生活的最高和最終權威，是神啟示的完整記錄。</p>',
  },
  {
    title: '三、人的境況',
    content:
      '<p>我們相信神按自己的形像造人，但人因悖逆而墮落。全人類生來就有罪性，與神隔絕，處於神公義的審判之下。人無法靠自己的努力恢復與神的關係。</p>',
  },
  {
    title: '四、耶穌基督',
    content:
      '<p>我們相信耶穌基督是完全的神，也是完全的人。祂由童貞女馬利亞所生，過無罪的生活，行了神蹟，被釘在十字架上為罪人代死，第三天從死裡復活，升天坐在父神的右邊。</p>',
  },
  {
    title: '五、基督十架的救贖',
    content:
      '<p>我們相信主耶穌基督為我們的罪而死，作為替代的贖罪祭。凡相信祂的人，都因祂所流的寶血而被稱為義。祂的死是完全的、充分的，足以贖一切人的罪。</p>',
  },
  {
    title: '六、聖靈',
    content:
      '<p>我們相信聖靈叫世人知罪，使信徒重生，從得救的那一刻起內住在他們裡面，賜能力使他們過敬虔的生活並事奉。聖靈光照聖經，分賜屬靈恩賜，建造教會。</p>',
  },
  {
    title: '七、教會',
    content:
      '<p>我們相信普世教會是基督的身體，由一切重生的信徒組成，基督是教會的元首。地方教會是受洗信徒的群體，為敬拜、教導、團契和傳福音而組織，遵行洗禮和聖餐。</p>',
  },
  {
    title: '八、基督徒的生活',
    content:
      '<p>我們相信神稱義的恩典不可與祂成聖的能力和目的分開。神命令我們至高地愛祂，犧牲地愛人，藉著禱告、服事、奉獻和順服祂的話語來活出信仰。</p>',
  },
  {
    title: '九、基督的再來',
    content:
      '<p>我們相信主耶穌基督將親自、有形地再來。祂的再來是教會有福的盼望，激勵我們過聖潔的生活和忠心的事奉。</p>',
  },
  {
    title: '十、回應與永恆的歸宿',
    content:
      '<p>我們相信神命令所有人悔改相信主耶穌基督。凡拒絕福音的人將面對永遠的刑罰；凡接受的人將享受與神同在的永生福樂。</p>',
  },
  {
    title: '十一、末後的事',
    content:
      '<p>我們相信身體的復活、義人的永恆福樂和惡人的永遠受苦。我們盼望新天新地，在那裡有義居住，神將擦去一切的眼淚。</p>',
  },
];

// ---------- Resolved beliefs (CMS ▸ fallback) ----------
const beliefs =
  aboutPage?.beliefs && aboutPage.beliefs.length > 0
    ? aboutPage.beliefs.map((b) => ({
        title: b.title,
        content: b.content?.length
          ? portableTextToHtml(b.content)
          : `<p>${b.title}</p>`,
      }))
    : fallbackBeliefs;
---

<BaseLayout title={title} description={description} lang="zh">
  <main id="main-content" data-pagefind-body class="beliefs-vision">

    <!-- Hero Banner -->
    <section class="beliefs-hero">
      <img class="beliefs-hero__img" src="/images/hero/bible.webp" alt="" fetchpriority="high" loading="eager" decoding="async" />
      <div class="beliefs-hero__overlay">
        <div class="beliefs-hero__content">
          <h1 class="beliefs-hero__title" data-reveal>信仰與願景</h1>
          <p class="beliefs-hero__subtitle" data-reveal>扎根聖經，靠恩典塑造，活出使命。</p>
        </div>
      </div>
    </section>

    <!-- Beliefs -->
    <section class="section" aria-labelledby="beliefs-heading">
      <div class="section__inner">
        <h2 class="section__heading" id="beliefs-heading" data-reveal>我們的信仰</h2>
        <p class="section__intro" data-reveal>
          以下核心信念根植於聖經，塑造了我們教會的身份，也指引我們作為耶穌基督跟隨者的共同生活。本信仰宣言遵循美國播道會（EFCA）十一條信仰宣言。
        </p>
        <div data-reveal>
          <Accordion items={beliefs} />
        </div>
      </div>
    </section>

    <!-- Scripture Banner -->
    <section class="scripture-banner" aria-label="經文">
      <img class="scripture-banner__img" src="/images/church/2023-retreat-praying.webp" alt="教會成員一同禱告" loading="lazy" />
      <div class="scripture-banner__overlay">
        <blockquote class="scripture-banner__quote" data-reveal>
          <p>「聖經都是神所默示的，於教訓、督責、使人歸正、教導人學義都是有益的，叫屬神的人得以完全，預備行各樣的善事。」</p>
          <cite>提摩太後書 3:16-17</cite>
        </blockquote>
      </div>
    </section>

    <!-- Ministries Callout -->
    <section class="ministries-callout ministries-callout--textured" aria-label="探索事工">
      <div class="ministries-callout__tex" style="background-image: url('/images/textures/valentin-beauvais-4YrVF0gVdjk-unsplash.jpg')"></div>
      <div class="ministries-callout__inner">
        <h2 class="ministries-callout__heading" data-reveal>看見信仰的行動</h2>
        <p class="ministries-callout__body" data-reveal>從敬拜聚會到小組團契，一起探索我們如何活出信仰。</p>
        <a href="/zh/ministries" class="ministries-callout__cta" data-reveal>
          探索事工
          <svg class="ministries-callout__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ================================================================
     HERO BANNER
     ================================================================ */
  .beliefs-hero {
    position: relative;
    min-height: 40vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background-color: var(--color-bg-dark);
  }

  .beliefs-hero__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
  }

  .beliefs-hero__overlay {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 40vh;
    width: 100%;
    background: linear-gradient(
      to bottom,
      rgba(26, 58, 44, 0.35) 0%,
      rgba(26, 58, 44, 0.65) 100%
    );
    padding: var(--space-16) var(--space-6);
  }

  .beliefs-hero__content {
    text-align: center;
    max-width: 36rem;
  }

  .beliefs-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.1;
    color: var(--base-50);
    margin-block-end: var(--space-3);
  }

  .beliefs-hero__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--base-200);
  }

  /* ================================================================
     CONTENT SECTIONS
     ================================================================ */
  .beliefs-vision {
    /* no top padding — hero handles it */
  }

  .section {
    padding-block: var(--space-16);
    position: relative;
    overflow: hidden;
  }

  .section__inner {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-6);
    position: relative;
    z-index: 2;
  }

  .section__heading {
    font-family: var(--font-heading);
    font-size: var(--text-4xl);
    color: var(--color-ink);
    margin-block-end: var(--space-4);
  }

  .section__intro {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    max-width: 48rem;
    margin-block-end: var(--space-10);
  }

  /* ================================================================
     SCRIPTURE BANNER
     ================================================================ */
  .scripture-banner {
    position: relative;
    min-height: 24rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .scripture-banner__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .scripture-banner__overlay {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 24rem;
    width: 100%;
    background: rgba(26, 58, 44, 0.78);
    padding: var(--space-12) var(--space-6);
  }

  .scripture-banner__quote {
    max-width: 40rem;
    text-align: center;
  }

  .scripture-banner__quote p {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-style: italic;
    font-weight: 400;
    line-height: var(--leading-relaxed);
    color: var(--base-50);
    margin-block-end: var(--space-4);
  }

  .scripture-banner__quote cite {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--primary-200);
  }

  /* ================================================================
     MINISTRIES CALLOUT
     ================================================================ */
  .ministries-callout {
    padding: var(--space-16) var(--space-6) calc(var(--space-16) + 2rem);
    background-color: var(--base-800);
    position: relative;
    overflow: hidden;
  }

  .ministries-callout--textured .ministries-callout__tex {
    position: absolute;
    inset: 0;
    z-index: 0;
    background-size: cover;
    background-position: center;
    pointer-events: none;
    opacity: 0.25;
    mix-blend-mode: soft-light;
  }

  .ministries-callout__inner {
    max-width: 36rem;
    margin-inline: auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .ministries-callout__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--base-50);
    margin-block-end: var(--space-3);
  }

  .ministries-callout__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--base-300);
    margin-block-end: var(--space-6);
  }

  .ministries-callout__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .ministries-callout__cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .ministries-callout__cta:hover {
    background-color: var(--primary-400);
    transform: translateY(-1px);
  }

  .ministries-callout__cta:hover .ministries-callout__cta-arrow {
    transform: translateX(4px);
  }

  .ministries-callout__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* ================================================================
     RESPONSIVE
     ================================================================ */
  @media (max-width: 767px) {
    .beliefs-hero {
      min-height: 30vh;
    }

    .beliefs-hero__overlay {
      min-height: 30vh;
    }

    .beliefs-hero__subtitle {
      font-size: var(--text-base);
    }

    .section {
      padding-block: var(--space-10);
    }

    .section__heading {
      font-size: var(--text-3xl);
    }

    .section__intro {
      font-size: var(--text-base);
    }

    .scripture-banner {
      min-height: 18rem;
    }

    .scripture-banner__overlay {
      min-height: 18rem;
    }

    .scripture-banner__quote p {
      font-size: var(--text-lg);
    }
  }
</style>
