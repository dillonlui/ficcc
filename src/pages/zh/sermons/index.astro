---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import SermonCard from '../../../components/SermonCard.astro';
import { getSermons } from '../../../lib/sanity';

const title = '證道 | FICCC';
const description = '浏览以萨卡华人基督教会的证道信息。按系列筛选，在线观看讲道。';

// ---------- CMS data (graceful fallback when Sanity is unreachable) ----------
let sermons: Awaited<ReturnType<typeof getSermons>> = [];

try {
  sermons = await getSermons('zh');
} catch {
  // Sanity unreachable — continue with empty array
}

// ---------- Extract distinct series for filter ----------
const allSeries = [...new Set(sermons.map((s) => s.series).filter(Boolean))] as string[];
---

<BaseLayout title={title} description={description} lang="zh">
  <main id="main-content" data-pagefind-body>
    <Hero
      title="證道"
      subtitle="聆听我们主日聚会的讲道信息"
      backgroundImage="/images/hero/worship.webp"
    />

    {sermons.length > 0 ? (
      <section class="sermons-listing" aria-label="讲道列表">
        <div class="sermons-listing__inner">
          {allSeries.length > 0 && (
            <nav class="filter-bar" aria-label="按系列筛选">
              <button class="filter-btn filter-btn--active" data-filter="all" type="button">
                全部
              </button>
              {allSeries.map((series) => (
                <button class="filter-btn" data-filter={series} type="button">
                  {series}
                </button>
              ))}
            </nav>
          )}

          <div class="sermons-grid" data-reveal>
            {sermons.map((sermon) => (
              <div class="sermons-grid__item" data-series={sermon.series ?? ''}>
                <SermonCard
                  title={sermon.title}
                  speaker={sermon.speaker}
                  date={sermon.date}
                  series={sermon.series}
                  scripture={sermon.scripture}
                  href={sermon.slug?.current ? `/zh/sermons/${sermon.slug.current}` : '#'}
                />
              </div>
            ))}
          </div>
        </div>
      </section>
    ) : (
      <section class="sermons-empty" aria-label="暂无讲道">
        <div class="sermons-empty__inner">
          <p class="sermons-empty__message">目前暂无讲道信息，请稍后再来查看。</p>
        </div>
      </section>
    )}

    <!-- Visit Callout -->
    <section class="visit-callout" aria-label="規劃來訪">
      <div class="visit-callout__tex" style="background-image: url('/images/textures/valentin-beauvais-4YrVF0gVdjk-unsplash.jpg')"></div>
      <div class="visit-callout__inner">
        <h2 class="visit-callout__heading" data-reveal>來和我們一起敬拜</h2>
        <p class="visit-callout__body" data-reveal>歡迎您親自來訪。了解聚會時間、地址及主日流程。</p>
        <a href="/zh/sundays" class="visit-callout__cta" data-reveal>
          規劃來訪
          <svg class="visit-callout__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items = document.querySelectorAll<HTMLElement>('.sermons-grid__item');

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      // Toggle active class
      filterBtns.forEach((b) => b.classList.remove('filter-btn--active'));
      btn.classList.add('filter-btn--active');

      // Show/hide cards
      items.forEach((item) => {
        if (filter === 'all' || item.dataset.series === filter) {
          item.removeAttribute('hidden');
        } else {
          item.setAttribute('hidden', '');
        }
      });
    });
  });
</script>

<style>
  .sermons-listing {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
  }

  .sermons-listing__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  /* ---------- Filter bar ---------- */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-block-end: var(--space-10);
    justify-content: center;
  }

  .filter-btn {
    appearance: none;
    border: 1px solid var(--color-stone);
    background-color: var(--color-bg);
    color: var(--color-body);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    padding: var(--space-2) var(--space-5);
    border-radius: 100vw;
    cursor: pointer;
    transition: background-color var(--transition), color var(--transition),
      border-color var(--transition);
  }

  .filter-btn:hover {
    border-color: var(--primary-500);
    color: var(--primary-500);
  }

  .filter-btn:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .filter-btn--active {
    background-color: var(--primary-500);
    border-color: var(--primary-500);
    color: var(--color-bg);
  }

  .filter-btn--active:hover {
    color: var(--color-bg);
  }

  /* ---------- Sermon grid ---------- */
  .sermons-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .sermons-grid__item[hidden] {
    display: none;
  }

  /* ---------- Empty state ---------- */
  .sermons-empty {
    padding: var(--space-20) var(--space-6);
    background-color: var(--color-bg);
  }

  .sermons-empty__inner {
    max-width: var(--max-width);
    margin-inline: auto;
    text-align: center;
  }

  .sermons-empty__message {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-body);
    line-height: var(--leading-relaxed);
  }

  /* ---------- Visit callout banner ---------- */
  .visit-callout {
    padding: var(--space-16) var(--space-6) calc(var(--space-16) + 2rem);
    background-color: var(--base-800);
    position: relative;
    overflow: hidden;
  }

  .visit-callout__tex {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    pointer-events: none;
    opacity: 0.25;
    mix-blend-mode: soft-light;
    z-index: 0;
  }

  .visit-callout__inner {
    max-width: 36rem;
    margin-inline: auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .visit-callout__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--base-50);
    margin-block-end: var(--space-3);
  }

  .visit-callout__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--base-300);
    margin-block-end: var(--space-6);
  }

  .visit-callout__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .visit-callout__cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .visit-callout__cta:hover {
    background-color: var(--primary-400);
    transform: translateY(-1px);
  }

  .visit-callout__cta:hover .visit-callout__cta-arrow {
    transform: translateX(4px);
  }

  .visit-callout__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1024px) {
    .sermons-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .sermons-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .sermons-listing {
      padding: var(--space-10) var(--space-4);
    }
  }
</style>
