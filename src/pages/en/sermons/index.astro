---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import { getSermons } from '../../../lib/sanity';
import { getLatestVideos, type YouTubeVideo } from '../../../lib/youtube';

export const prerender = false;

const title = 'Sermons | FICCC';
const description = 'Browse sermons from First Ithaca Chinese Christian Church. Watch messages from our Sunday gatherings.';

// ---------- Fetch from YouTube + Sanity in parallel ----------
let ytVideos: YouTubeVideo[] = [];
let sanitySermons: Awaited<ReturnType<typeof getSermons>> = [];

try {
  [ytVideos, sanitySermons] = await Promise.all([
    getLatestVideos(7),
    getSermons('en').catch(() => []),
  ]);
} catch {
  // Both failed — continue with empty arrays
}

// ---------- Build merged sermon list ----------
// YouTube is the primary source; Sanity enriches with series, speaker, scripture
interface MergedSermon {
  videoId: string;
  title: string;
  date: string;
  thumbnail: string;
  speaker?: string;
  series?: string;
  scripture?: string;
  slug?: string;
}

const sanityByVideoId = new Map(
  sanitySermons
    .filter((s) => s.videoId)
    .map((s) => [s.videoId!, s]),
);

const mergedSermons: MergedSermon[] = ytVideos.map((yt) => {
  const override = sanityByVideoId.get(yt.videoId);
  return {
    videoId: yt.videoId,
    title: override?.title ?? yt.title,
    date: override?.date ?? yt.date,
    thumbnail: yt.thumbnail,
    speaker: override?.speaker,
    series: override?.series,
    scripture: override?.scripture,
    slug: override?.slug?.current,
  };
});

const latestSermon = mergedSermons[0] ?? null;
const recentSermons = mergedSermons.slice(1);

// Format date for display
function formatDate(dateStr: string): string {
  if (!dateStr) return '';
  const d = new Date(dateStr + 'T00:00:00');
  return d.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' });
}
---

<BaseLayout title={title} description={description}>
  <main id="main-content" data-pagefind-body>
    <Hero
      title="Sermons"
      subtitle="Explore messages from our Sunday gatherings"
      backgroundImage="/images/hero/worship.webp"
    />

    {latestSermon ? (
      <Fragment>
        {/* Latest Sermon */}
        <section class="latest-sermon" aria-label="Latest sermon">
          <div class="latest-sermon__inner">
            <h2 class="latest-sermon__heading" data-reveal>Latest Sermon</h2>
            <div class="latest-sermon__embed" data-reveal>
              <div class="video-wrapper">
                <iframe
                  src={`https://www.youtube-nocookie.com/embed/${latestSermon.videoId}`}
                  title={latestSermon.title}
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
              <div class="latest-sermon__info">
                <h3 class="latest-sermon__title">{latestSermon.title}</h3>
                <p class="latest-sermon__meta">
                  {formatDate(latestSermon.date)}
                  {latestSermon.speaker && ` · ${latestSermon.speaker}`}
                </p>
                {latestSermon.series && (
                  <p class="latest-sermon__series">{latestSermon.series}</p>
                )}
              </div>
            </div>
          </div>
        </section>

        {/* Recent Sermons Grid */}
        {recentSermons.length > 0 && (
          <section class="sermons-listing" aria-label="Recent sermons">
            <div class="sermons-listing__inner">
              <h2 class="sermons-listing__heading" data-reveal>Recent Sermons</h2>
              <div class="sermons-grid" data-reveal>
                {recentSermons.map((sermon) => (
                  <div class="sermon-card">
                    <div class="sermon-card__thumb">
                      <img
                        src={sermon.thumbnail}
                        alt={sermon.title}
                        loading="lazy"
                        width="320"
                        height="180"
                      />
                      <a
                        href={`https://www.youtube.com/watch?v=${sermon.videoId}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="sermon-card__play"
                        aria-label={`Watch ${sermon.title}`}
                      >
                        <svg width="48" height="48" viewBox="0 0 48 48" fill="none" aria-hidden="true">
                          <circle cx="24" cy="24" r="24" fill="rgba(0,0,0,0.6)"/>
                          <polygon points="19,14 19,34 35,24" fill="white"/>
                        </svg>
                      </a>
                    </div>
                    <div class="sermon-card__info">
                      <h3 class="sermon-card__title">
                        <a href={`https://www.youtube.com/watch?v=${sermon.videoId}`} target="_blank" rel="noopener noreferrer">
                          {sermon.title}
                        </a>
                      </h3>
                      <p class="sermon-card__date">
                        {formatDate(sermon.date)}
                        {sermon.speaker && ` · ${sermon.speaker}`}
                      </p>
                      {sermon.series && (
                        <p class="sermon-card__series">{sermon.series}</p>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>
        )}

        {/* YouTube Channel CTA */}
        <section class="yt-cta" aria-label="YouTube channel">
          <div class="yt-cta__inner">
            <h2 class="yt-cta__heading">Sermon Archive</h2>
            <p class="yt-cta__body">Browse the full library of sermons from our English ministry on YouTube.</p>
            <a
              href="https://www.youtube.com/@FICCCenglish"
              target="_blank"
              rel="noopener noreferrer"
              class="yt-cta__link"
            >
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/>
              </svg>
              Visit Our YouTube Channel
            </a>
          </div>
        </section>
      </Fragment>
    ) : (
      <section class="sermons-empty" aria-label="Sermons">
        <div class="sermons-empty__inner">
          <p class="sermons-empty__message">
            Sermons are coming soon. In the meantime, visit our
            <a href="https://www.youtube.com/@FICCCenglish" target="_blank" rel="noopener noreferrer">YouTube channel</a>
            to watch past messages.
          </p>
        </div>
      </section>
    )}

    <!-- Visit callout -->
    <section class="visit-callout" aria-label="Plan Your Visit">
      <div class="visit-callout__tex" style="background-image: url('/images/textures/valentin-beauvais-4YrVF0gVdjk-unsplash.jpg')"></div>
      <div class="visit-callout__inner">
        <h2 class="visit-callout__heading" data-reveal>Come worship with us</h2>
        <p class="visit-callout__body" data-reveal>
          We'd love to meet you in person. Find service times, directions, and what to expect on a Sunday morning.
        </p>
        <a href="/en/visit" class="visit-callout__cta" data-reveal>
          Plan Your Visit
          <svg class="visit-callout__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .sermons-listing {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
  }

  .sermons-listing__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  /* ---------- Sermon grid ---------- */
  .sermons-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  /* ---------- Empty state ---------- */
  .sermons-empty {
    padding: var(--space-20) var(--space-6);
    background-color: var(--color-bg);
  }

  /* ---------- Latest Sermon ---------- */
  .latest-sermon {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
  }

  .latest-sermon__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .latest-sermon__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    text-align: center;
    margin-block-end: var(--space-8);
  }

  .latest-sermon__embed {
    max-width: 48rem;
    margin-inline: auto;
  }

  .video-wrapper {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: var(--radius-xl);
    background-color: var(--color-ink);
  }

  .video-wrapper iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .latest-sermon__info {
    margin-block-start: var(--space-4);
    text-align: center;
  }

  .latest-sermon__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-ink);
  }

  .latest-sermon__meta {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-body);
    margin-block-start: var(--space-1);
  }

  .latest-sermon__series {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--primary-500);
    margin-block-start: var(--space-2);
  }

  .sermons-listing__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    text-align: center;
    margin-block-end: var(--space-10);
  }

  /* ---------- Sermon card (YouTube) ---------- */
  .sermon-card {
    border-radius: var(--radius-xl);
    overflow: hidden;
    background-color: var(--color-stone);
    transition: transform var(--transition), box-shadow var(--transition);
  }

  .sermon-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  .sermon-card__thumb {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .sermon-card__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sermon-card__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.8;
    transition: opacity var(--transition);
  }

  .sermon-card__play:hover {
    opacity: 1;
  }

  .sermon-card__info {
    padding: var(--space-4);
  }

  .sermon-card__title {
    font-family: var(--font-heading);
    font-size: var(--text-base);
    line-height: var(--leading-snug);
    color: var(--color-ink);
  }

  .sermon-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .sermon-card__title a:hover {
    color: var(--color-terracotta-dark);
  }

  .sermon-card__date {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-body);
    margin-block-start: var(--space-1);
  }

  .sermon-card__series {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--primary-500);
    margin-block-start: var(--space-1);
  }

  /* ---------- YouTube CTA ---------- */
  .yt-cta {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-stone);
    text-align: center;
  }

  .yt-cta__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .yt-cta__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    margin-block-end: var(--space-3);
  }

  .yt-cta__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-body);
    margin-block-end: var(--space-6);
  }

  .yt-cta__link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-bg);
    background-color: #c4302b;
    padding: var(--space-3) var(--space-8);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .yt-cta__link:hover {
    background-color: #a32722;
    transform: translateY(-1px);
  }

  .yt-cta__link:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .sermons-empty__inner {
    max-width: var(--max-width);
    margin-inline: auto;
    text-align: center;
  }

  .sermons-empty__message {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: var(--color-body);
    line-height: var(--leading-relaxed);
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1024px) {
    .sermons-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .sermons-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .sermons-listing {
      padding: var(--space-10) var(--space-4);
    }
  }

  /* Visit callout banner */
  .visit-callout {
    padding: var(--space-16) var(--space-6) calc(var(--space-16) + 2rem);
    background-color: var(--base-800);
    position: relative;
    overflow: hidden;
  }

  .visit-callout__tex {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    pointer-events: none;
    opacity: 0.25;
    mix-blend-mode: soft-light;
    z-index: 0;
  }

  .visit-callout__inner {
    max-width: 36rem;
    margin-inline: auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .visit-callout__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--base-50);
    margin-block-end: var(--space-3);
  }

  .visit-callout__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--base-300);
    margin-block-end: var(--space-6);
  }

  .visit-callout__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .visit-callout__cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .visit-callout__cta:hover {
    background-color: var(--primary-400);
    transform: translateY(-1px);
  }

  .visit-callout__cta:hover .visit-callout__cta-arrow {
    transform: translateX(4px);
  }

  .visit-callout__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }
</style>
