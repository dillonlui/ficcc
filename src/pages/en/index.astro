---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getHomePage, getSermons, getEvents, urlForImage } from '../../lib/sanity';
import { buildChurchJsonLd, buildWebSiteJsonLd } from '../../lib/structured-data';

const title = 'First Ithaca Chinese Christian Church | 伊的家華人基督教會';
const description =
  'A Chinese-heritage, university-adjacent Christian community in Ithaca, NY. Sunday gathering at 9:45am, 429 Mitchell Street.';

let homePage: Awaited<ReturnType<typeof getHomePage>> = null;
let sermons: Awaited<ReturnType<typeof getSermons>> = [];
let events: Awaited<ReturnType<typeof getEvents>> = [];

try {
  [homePage, sermons, events] = await Promise.all([
    getHomePage('en'),
    getSermons('en'),
    getEvents('en'),
  ]);
} catch {}

const heroImage = homePage?.heroImage
  ? urlForImage(homePage.heroImage, { width: 1600 })
  : '/images/church/picnic-leland-guitar.webp';
const heroTitle = homePage?.heroTitle || 'Welcome Home';
const heroSubtitle =
  homePage?.heroSubtitle ||
  'Go deeper in God\'s Word, in gospel-shaped community, and in everyday discipleship.';

const siteUrl = (Astro.site ?? new URL('https://ficcc.org')).href;
const homeJsonLd = {
  '@context': 'https://schema.org',
  '@graph': [buildChurchJsonLd(), buildWebSiteJsonLd(siteUrl)],
};
---

<BaseLayout title={title} description={description} jsonLd={homeJsonLd} ogType="website">
  <main id="main-content" data-pagefind-body>

    <!-- ============ HERO — tall, editorial, people-first ============ -->
    <section class="hero-home">
      <img
        class="hero-home__img"
        src={heroImage}
        alt=""
        fetchpriority="high"
        loading="eager"
        decoding="async"
      />
      <div class="hero-home__overlay">
        <div class="hero-home__content">
          <h1 class="hero-home__title" data-reveal>{heroTitle}</h1>
          <p class="hero-home__subtitle" data-reveal>{heroSubtitle}</p>
          <!-- Service info — two-column: times left, location right -->
          <div class="hero-info" data-reveal>
            <div class="hero-info__times">
              <div class="hero-info__item">
                <span class="hero-info__label">
                  <svg class="hero-info__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2L3 9v11a2 2 0 002 2h4v-7h6v7h4a2 2 0 002-2V9l-9-7z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><path d="M9 2v4h6V2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  Sunday Gathering
                </span>
                <span class="hero-info__value">9:45 AM</span>
              </div>
              <div class="hero-info__item">
                <span class="hero-info__label">
                  <svg class="hero-info__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="1.5"/><path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                  Discipleship Groups
                </span>
                <span class="hero-info__value">11:00 AM</span>
              </div>
            </div>
            <div class="hero-info__divider"></div>
            <div class="hero-info__location">
              <div class="hero-info__item">
                <span class="hero-info__label">
                  <svg class="hero-info__icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.5"/></svg>
                  Address
                </span>
                <span class="hero-info__value">429 Mitchell Street<br/>Ithaca, NY 14850</span>
              </div>
            </div>
          </div>

          <a class="hero-home__cta" href="/en/visit" data-reveal>
            Plan Your Visit
            <svg class="hero-home__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>
    </section>

    <!-- ============ SECTION 1: Go Deeper ============ -->
    <section class="split" aria-label="Who We Are">
      <div class="split__inner">
        <div class="split__media" data-reveal>
          <img src="/images/church/img-8212.webp" alt="FICCC congregation gathered for worship" loading="lazy" />
        </div>
        <div class="split__content" data-reveal>
          <h2 class="split__heading">Go Deeper at FICCC</h2>
          <p class="split__body">
            If you've lived in Ithaca for years, just arrived as a visiting scholar,
            or are a student far from home, there is a place for you here.
          </p>
          <a href="/en/about" class="split__link">Learn more about us <svg class="link-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </section>

    <!-- ============ SECTION 2: Sundays ============ -->
    <section class="split split--reversed split--tinted split--textured" aria-label="Sunday Experience">
      <div class="split__tex" style="background-image: url('/images/textures/kiwihug-qv05FvdE26k-unsplash.jpg')"></div>
      <div class="split__inner">
        <div class="split__media" data-reveal>
          <img src="/images/church/pxl-20250813-130502778.webp" alt="FICCC church building at 429 Mitchell Street" loading="lazy" />
        </div>
        <div class="split__content" data-reveal>
          <h2 class="split__heading">Sunday Mornings</h2>
          <p class="split__body">
            At 9:45am we gather for singing, preaching from the Bible, and the
            Lord's Supper. At 11:00am we move into Discipleship Groups for
            discussion and prayer. Then we eat lunch together - usually Chinese food.
          </p>
          <a href="/en/visit" class="split__link">Plan your first visit <svg class="link-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </section>

    <!-- ============ SECTION 3: Community ============ -->
    <section class="split" aria-label="Community">
      <div class="split__inner">
        <div class="split__media" data-reveal>
          <img src="/images/church/2023-retreat-praying.webp" alt="Church members praying together at 2023 retreat" loading="lazy" />
        </div>
        <div class="split__content" data-reveal>
          <h2 class="split__heading">Find Community</h2>
          <p class="split__body">
            Bible studies, fellowship groups, mission trips, and shared meals.
            We challenge people to get involved in serving - in our church,
            on campus, and in the Ithaca community.
          </p>
          <a href="/en/ministries" class="split__link">Explore ministries <svg class="link-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </section>

    <!-- ============ SECTION 4: Sermons ============ -->
    <section class="split split--reversed split--tinted split--textured" aria-label="Sermons">
      <div class="split__tex" style="background-image: url('/images/textures/kiwihug-qv05FvdE26k-unsplash.jpg')"></div>
      <div class="split__inner">
        <div class="split__media" data-reveal>
          <img src="/images/church/img-0316.webp" alt="FICCC service" loading="lazy" />
        </div>
        <div class="split__content" data-reveal>
          <h2 class="split__heading">Watch Sermons</h2>
          <p class="split__body">
            Catch up on recent messages or explore past teaching series.
            Our English ministry uploads sermons weekly to YouTube.
          </p>
          <a href="/en/sermons" class="split__link">Browse sermons <svg class="link-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
        </div>
      </div>
    </section>

    <!-- ============ SECTION 5: Bridging Cultures banner ============ -->
    <section class="banner" aria-label="Bridging Cultures">
      <img
        class="banner__img"
        src="/images/church/picnic-sunmi-lordina-tiffany-linnea.webp"
        alt="Diverse community members together"
        loading="lazy"
      />
      <div class="banner__overlay">
        <div class="banner__content" data-reveal>
          <h2 class="banner__heading">Bridging Cultures &amp; Generations</h2>
          <p class="banner__body">
            We celebrate our Chinese heritage while building a church home that
            welcomes students, families, and neighbors of every background.
          </p>
          <a href="/en/contact" class="banner__cta">Get in touch</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  /* ================================================================
     HERO — tall, editorial, people-first
     ================================================================ */
  .hero-home {
    position: relative;
    min-height: 85vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    background-color: var(--color-bg-dark);
  }

  .hero-home__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
  }

  .hero-home__overlay {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(
      to bottom,
      rgba(26, 58, 44, 0.25) 0%,
      rgba(26, 58, 44, 0.55) 60%,
      rgba(26, 58, 44, 0.75) 100%
    );
    padding: var(--space-16) var(--space-6);
  }

  .hero-home__content {
    text-align: center;
    max-width: 42rem;
  }

  .hero-home__title {
    font-family: var(--font-heading);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.1;
    color: var(--color-bg);
    margin-block-end: var(--space-4);
  }

  .hero-home__subtitle {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    line-height: var(--leading-relaxed);
    color: var(--color-stone);
    max-width: 32rem;
    margin-inline: auto;
    margin-block-end: var(--space-6);
  }

  .hero-home__cta {
    margin-top: var(--space-8);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .hero-home__cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-home__cta:hover {
    background-color: var(--primary-600);
    transform: translateY(-1px);
  }

  .hero-home__cta:hover .hero-home__cta-arrow {
    transform: translateX(4px);
  }

  .hero-home__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* ================================================================
     HERO INFO — two-column: times | location
     ================================================================ */
  .hero-info {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    margin-top: var(--space-6);
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-xl);
    padding: var(--space-5) var(--space-6);
    text-align: left;
    max-width: 32rem;
  }

  .hero-info__times {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hero-info__item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .hero-info__divider {
    width: 1px;
    align-self: stretch;
    background: rgba(255, 255, 255, 0.2);
    flex-shrink: 0;
  }

  .hero-info__location {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .hero-info__icon {
    flex-shrink: 0;
    color: currentColor;
    vertical-align: -2px;
  }

  .hero-info__label {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.55);
  }

  .hero-info__value {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    padding-left: 19px; /* align with label text (14px icon + 5px gap) */
  }

  /* ================================================================
     SPLIT SECTIONS — image + text, alternating
     ================================================================ */
  .split {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
    position: relative;
    overflow: hidden;
  }

  .split--textured .split__tex {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    pointer-events: none;
    opacity: 0.35;
    z-index: 0;
  }

  .split--textured .split__inner {
    position: relative;
    z-index: 1;
  }

  .split--tinted {
    background-color: var(--color-stone);
  }

  .split__inner {
    max-width: var(--max-width);
    margin-inline: auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  .split--reversed .split__inner {
    direction: rtl;
  }

  .split--reversed .split__inner > * {
    direction: ltr;
  }

  .split__media {
    border-radius: var(--radius-xl);
    overflow: hidden;
  }

  .split__media img {
    width: 100%;
    height: 100%;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .split__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    margin-block-end: var(--space-4);
  }

  .split__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    margin-block-end: var(--space-6);
  }

  .split__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--primary-500);
    text-decoration: none;
    padding: var(--space-3) var(--space-6);
    border: 2px solid var(--primary-500);
    border-radius: 100vw;
    transition: background-color var(--transition), color var(--transition);
  }

  .split__link .link-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .split__link:hover {
    background-color: var(--primary-500);
    color: var(--base-50);
  }

  .split__link:hover .link-arrow {
    transform: translateX(4px);
  }

  .split__link:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* ================================================================
     BANNER — full-width closing section
     ================================================================ */
  .banner {
    position: relative;
    min-height: 32rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .banner__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .banner__overlay {
    position: absolute;
    inset: 0;
    background: rgba(26, 58, 44, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-16) var(--space-6);
  }

  .banner__content {
    max-width: 40rem;
    text-align: center;
  }

  .banner__heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-bg);
    margin-block-end: var(--space-4);
  }

  .banner__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-stone);
    margin-block-end: var(--space-8);
  }

  .banner__cta {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-bg);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .banner__cta:hover {
    background-color: var(--primary-600);
    transform: translateY(-1px);
  }

  .banner__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* ================================================================
     RESPONSIVE
     ================================================================ */
  @media (max-width: 768px) {
    .hero-home {
      min-height: 70vh;
    }

    .hero-home__subtitle {
      font-size: var(--text-base);
    }

    .hero-info {
      flex-direction: column;
      gap: var(--space-4);
      text-align: left;
    }

    .hero-info__times {
      flex-direction: row;
      gap: var(--space-6);
    }

    .hero-info__divider {
      width: 100%;
      height: 1px;
    }

    .hero-info__value br {
      display: none;
    }

    .hero-info__location .hero-info__value {
      white-space: nowrap;
    }

    .split__inner {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .split--reversed .split__inner {
      direction: ltr;
    }

    .split__heading {
      font-size: var(--text-2xl);
    }

    .split__body {
      font-size: var(--text-base);
    }

    .banner {
      min-height: 26rem;
    }

    .banner__heading {
      font-size: var(--text-2xl);
    }
  }
</style>
