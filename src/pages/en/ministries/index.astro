---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
import MinistryCard from '../../../components/MinistryCard.astro';
import { getMinistries, urlForImage, type Ministry } from '../../../lib/sanity';

const title = 'Community & Ministries | FICCC';
const description = 'Explore the ministries and community groups at First Ithaca Chinese Christian Church.';

let ministries: Ministry[] = [];

try {
  ministries = await getMinistries('en');
} catch {
  // Sanity unreachable — continue with empty array
}

// Use all ministries (no slug filter needed — no detail pages)

// ---------- Fallback fellowship groups (from em.ficcc.org + cm.ficcc.org) ----------
const fallbackGroups = [
  {
    name: 'Discipleship Groups',
    image: '/images/church/img-0316.webp',
    meetingTime: 'Sundays 11:00 AM',
    description: 'Small groups for deeper Bible study and mutual encouragement after the Sunday gathering.',
  },
  {
    name: 'Midweek Bible Study',
    image: '/images/church/midweek-bible-study.webp',
    meetingTime: 'Thursdays 7:00 PM',
    description: 'A weekly evening study open to everyone. Come dig into Scripture with us.',
  },
  {
    name: 'Youth Group',
    image: '/images/church/youth-ministry-12.jpg',
    meetingTime: 'Fridays 7:30 PM',
    description: 'Fellowship and fun for middle and high school students.',
  },
  {
    name: 'Monthly Prayer Meeting',
    image: '/images/church/2023-retreat-praying.webp',
    meetingTime: '1st Wednesday 7:30 PM',
    description: 'A monthly gathering to pray together for our church, community, and world.',
  },
  {
    name: 'Children\'s Sunday School',
    image: '/images/church/img-1594.webp',
    meetingTime: 'Sundays 11:15 AM',
    description: 'Age-appropriate Bible teaching and activities for kids during the Sunday School hour.',
  },
  {
    name: 'Adult Sunday School',
    image: '/images/ministries/campus.jpg',
    meetingTime: 'Sundays 11:15 AM',
    description: 'Topical and book-by-book studies for adults of all backgrounds.',
  },
];
---

<BaseLayout title={title} description={description}>
  <main id="main-content" data-pagefind-body>
    <Hero
      title="Community & Ministries"
      subtitle="Get connected through our church ministries"
      backgroundImage="/images/hero/community.webp"
    />

    {ministries.length > 0 ? (
      <section class="ministries-listing" aria-label="Ministries">
        <div class="ministries-listing__inner">
          <div class="ministries-grid" data-reveal>
            {ministries.map((ministry) => (
              <MinistryCard
                name={ministry.name}
                image={urlForImage(ministry.image, { width: 600 }) || undefined}
                meetingTime={ministry.meetingTime}
              />
            ))}
          </div>
        </div>
      </section>
    ) : (
      <section class="ministries-listing" aria-label="Ministries and Groups">
        <div class="ministries-listing__inner">
          <p class="ministries-listing__intro" data-reveal>
            There are many ways to get connected at FICCC. Here are some of our regular gatherings and groups.
          </p>
          <div class="ministries-grid" data-reveal>
            {fallbackGroups.map((group) => (
              <div class="group-card">
                <div class="group-card__image">
                  <img src={group.image} alt="" loading="lazy" />
                </div>
                <div class="group-card__body">
                  <h3 class="group-card__name">{group.name}</h3>
                  {group.meetingTime && (
                    <p class="group-card__time">{group.meetingTime}</p>
                  )}
                  <p class="group-card__desc">{group.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Sermons callout -->
    <section class="sermons-callout" aria-label="Watch Sermons">
      <div class="sermons-callout__tex" style="background-image: url('/images/textures/valentin-beauvais-4YrVF0gVdjk-unsplash.jpg')"></div>
      <div class="sermons-callout__inner">
        <h2 class="sermons-callout__heading" data-reveal>Hear what we're learning</h2>
        <p class="sermons-callout__body" data-reveal>
          Catch up on recent messages or explore past teaching series from our Sunday gatherings.
        </p>
        <a href="/en/sermons" class="sermons-callout__cta" data-reveal>
          Watch Sermons
          <svg class="sermons-callout__cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .ministries-listing {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
  }

  .ministries-listing__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .ministries-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .ministries-listing__intro {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    text-align: center;
    max-width: 40rem;
    margin-inline: auto;
    margin-block-end: var(--space-10);
  }

  .group-card {
    background-color: var(--color-stone);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .group-card__image {
    aspect-ratio: 16 / 10;
    overflow: hidden;
  }

  .group-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .group-card__body {
    padding: var(--space-6);
  }

  .group-card__name {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin-block-end: var(--space-2);
  }

  .group-card__time {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--primary-500);
    margin-block-end: var(--space-3);
  }

  .group-card__desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    margin: 0;
  }

  @media (max-width: 1024px) {
    .ministries-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .ministries-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .ministries-listing {
      padding: var(--space-10) var(--space-4);
    }
  }

  /* Sermons callout banner */
  .sermons-callout {
    padding: var(--space-16) var(--space-6) calc(var(--space-16) + 2rem);
    background-color: var(--base-800);
    position: relative;
    overflow: hidden;
  }

  .sermons-callout__tex {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    pointer-events: none;
    opacity: 0.25;
    mix-blend-mode: soft-light;
    z-index: 0;
  }

  .sermons-callout__inner {
    max-width: 36rem;
    margin-inline: auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .sermons-callout__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--base-50);
    margin-block-end: var(--space-3);
  }

  .sermons-callout__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--base-300);
    margin-block-end: var(--space-6);
  }

  .sermons-callout__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .sermons-callout__cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .sermons-callout__cta:hover {
    background-color: var(--primary-400);
    transform: translateY(-1px);
  }

  .sermons-callout__cta:hover .sermons-callout__cta-arrow {
    transform: translateX(4px);
  }

  .sermons-callout__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }
</style>
