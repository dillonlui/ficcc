---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import { getGivePage, urlForImage, portableTextToHtml } from '../../lib/sanity';

const title = 'Give | First Ithaca Chinese Christian Church';
const description =
  'Support the mission of First Ithaca Chinese Christian Church through your generous giving.';

// ---------- CMS data (graceful fallback when Sanity is unreachable) ----------
let givePage: Awaited<ReturnType<typeof getGivePage>> = null;
try {
  givePage = await getGivePage('en');
} catch {}

// ---------- Resolved data (CMS ▸ fallback) ----------
const heroImage = givePage?.heroImage
  ? urlForImage(givePage.heroImage, { width: 1600 })
  : '/images/textures/adam-vradenburg-_gu7E90QChU-unsplash.jpg';
const heroTitle = givePage?.heroTitle || 'Give';
const heroSubtitle = givePage?.heroSubtitle || 'Your generosity makes a difference';

const whyWeGiveHeading = givePage?.whyWeGiveHeading || 'Why We Give';
const whyWeGiveBodyHtml =
  givePage?.whyWeGiveBody && givePage.whyWeGiveBody.length > 0
    ? portableTextToHtml(givePage.whyWeGiveBody)
    : null;

const scriptureQuote = givePage?.scriptureQuote || 'Each of you should give what you have decided in your heart to give, not reluctantly or under compulsion, for God loves a cheerful giver.';
const scriptureCitation = givePage?.scriptureCitation || '2 Corinthians 9:7 (NIV)';

const fallbackGivingMethods = [
  {
    title: 'Online via PayPal',
    description: 'Give securely online using PayPal. You can use a PayPal account, debit card, or credit card.',
    icon: 'globe' as const,
    link: 'https://www.paypal.com/donate/?cmd=_donations&business=ficccfinance1%40gmail.com&item_name=First+Ithaca+Chinese+Christian+Church+Offering&currency_code=USD&source=url',
    linkText: 'Give with PayPal',
  },
  {
    title: 'By Check',
    description: 'Make checks payable to First Ithaca Chinese Christian Church and mail to:',
    icon: 'envelope' as const,
    address: 'First Ithaca Chinese Christian Church\n429 Mitchell Street\nIthaca, NY 14850',
  },
  {
    title: 'In Person',
    description: 'Offering envelopes are available at our Sunday service. You can place your gift in the offering box located in the sanctuary.',
    icon: 'people' as const,
    note: 'Sundays at 9:45 AM · 429 Mitchell Street',
  },
];

const givingMethods =
  givePage?.givingMethods && givePage.givingMethods.length > 0
    ? givePage.givingMethods
    : fallbackGivingMethods;

const questionsHeading = givePage?.questionsHeading || 'Questions?';
const questionsBody = givePage?.questionsBody || "If you have questions about giving, tax-deductible receipts, or other ways to support our church, please don't hesitate to reach out.";

const iconSvgs: Record<string, string> = {
  globe: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>',
  envelope: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
  people: '<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>',
};
---

<BaseLayout title={title} description={description}>
  <main id="main-content" data-pagefind-body>
    <Hero
      title={heroTitle}
      subtitle={heroSubtitle}
      backgroundImage={heroImage}
    />

    <!-- Why We Give -->
    <section class="give-section" aria-label="Why We Give">
      <div class="give-section__inner">
        <h2 class="section-heading" data-reveal>{whyWeGiveHeading}</h2>
        {whyWeGiveBodyHtml ? (
          <div class="give-prose" data-reveal set:html={whyWeGiveBodyHtml} />
        ) : (
          <div class="give-prose" data-reveal>
            <p>
              Giving is an act of worship and trust. When we give generously, we
              participate in God's work: supporting our church community, caring
              for those in need, and sharing the good news of Jesus Christ.
            </p>
            <blockquote class="give-verse">
              <p>
                "{scriptureQuote}"
              </p>
              <cite>{scriptureCitation}</cite>
            </blockquote>
            <p>
              Whether it's your first time giving or you've been supporting our
              church for years, every gift helps us continue serving our community
              in Ithaca and beyond. Thank you for your faithfulness.
            </p>
          </div>
        )}
      </div>
    </section>

    <!-- Ways to Give -->
    <section class="give-section give-section--alt" aria-label="Ways to Give">
      <div class="give-section__inner">
        <h2 class="section-heading" data-reveal>Ways to Give</h2>
        <div class="give-methods" data-reveal-stagger>
          {givingMethods.map((method) => (
            <div class="give-method" data-reveal>
              {method.icon && iconSvgs[method.icon] && (
                <div class="give-method__icon" aria-hidden="true" set:html={iconSvgs[method.icon]} />
              )}
              <h3 class="give-method__title">{method.title}</h3>
              {method.description && (
                <p class="give-method__desc" set:html={method.description} />
              )}
              {method.link && method.linkText && (
                <a
                  class="give-method__link"
                  href={method.link}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  {method.linkText}
                  <svg class="cta-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </a>
              )}
              {method.address && (
                <address class="give-method__address" set:html={method.address.replace(/\n/g, '<br />')} />
              )}
              {method.note && (
                <p class="give-method__note">{method.note}</p>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Questions -->
    <section class="give-questions" aria-label="Questions about Giving">
      <div class="give-questions__tex" style="background-image: url('/images/textures/valentin-beauvais-4YrVF0gVdjk-unsplash.jpg')"></div>
      <div class="give-questions__inner">
        <h2 class="give-questions__heading" data-reveal>{questionsHeading}</h2>
        <p class="give-questions__body" data-reveal>
          {questionsBody}
        </p>
        <a href="/en/contact" class="give-questions__cta" data-reveal>
          Contact Us
          <svg class="cta-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>

<style is:global>
  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    text-align: center;
    margin-block-end: var(--space-10);
  }

  .give-section {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
  }

  .give-section--alt {
    background-color: var(--color-stone);
  }

  .give-section__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  /* ---------- Prose ---------- */
  .give-prose {
    max-width: 52rem;
    margin-inline: auto;
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
  }

  .give-prose p {
    margin-block-end: var(--space-4);
  }

  .give-prose p:last-child {
    margin-block-end: 0;
  }

  .give-prose a {
    color: var(--primary-500);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .give-prose a:hover {
    color: var(--primary-600);
  }

  /* ---------- Verse ---------- */
  .give-verse {
    border-inline-start: 3px solid var(--primary-400);
    padding: var(--space-6) var(--space-8);
    margin: var(--space-8) 0;
    background-color: var(--primary-50);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .give-verse p {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-style: italic;
    line-height: var(--leading-relaxed);
    color: var(--color-ink);
    margin-block-end: var(--space-2);
  }

  .give-verse cite {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    font-weight: 600;
    color: var(--primary-600);
  }

  /* ---------- Methods Grid ---------- */
  .give-methods {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-8);
  }

  .give-method {
    background-color: var(--color-bg);
    border-radius: var(--radius-xl);
    border: 1px solid var(--base-300);
    padding: var(--space-8) var(--space-6);
    text-align: center;
  }

  .give-method__icon {
    color: var(--primary-500);
    margin-block-end: var(--space-4);
    display: flex;
    justify-content: center;
  }

  .give-method__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin-block-end: var(--space-3);
  }

  .give-method__desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    margin-block-end: var(--space-4);
  }

  .give-method__desc strong {
    color: var(--color-ink);
  }

  .give-method__link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .give-method__link .cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .give-method__link:hover {
    background-color: var(--primary-600);
    transform: translateY(-1px);
  }

  .give-method__link:hover .cta-arrow {
    transform: translateX(4px);
  }

  .give-method__link:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .give-method__address {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    line-height: var(--leading-relaxed);
    color: var(--color-body);
  }

  .give-method__note {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--primary-500);
    font-weight: 600;
  }

  /* ---------- Questions Section — forest canopy background ---------- */
  .give-questions {
    position: relative;
    overflow: hidden;
    background-color: var(--base-800);
    padding: var(--space-16) var(--space-6) calc(var(--space-16) + 2rem);
  }

  .give-questions__tex {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    pointer-events: none;
    opacity: 0.25;
    mix-blend-mode: soft-light;
    z-index: 0;
  }

  .give-questions__inner {
    max-width: 42rem;
    margin-inline: auto;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .give-questions__heading {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    color: var(--base-50);
    margin-block-end: var(--space-3);
  }

  .give-questions__body {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--base-200);
    margin-block-end: var(--space-6);
  }

  .give-questions__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--base-50);
    background-color: var(--primary-500);
    padding: var(--space-3) var(--space-8);
    border-radius: 100vw;
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .give-questions__cta .cta-arrow {
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .give-questions__cta:hover {
    background-color: var(--primary-400);
    transform: translateY(-1px);
  }

  .give-questions__cta:hover .cta-arrow {
    transform: translateX(4px);
  }

  .give-questions__cta:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 768px) {
    .section-heading {
      font-size: var(--text-2xl);
    }

    .give-prose {
      font-size: var(--text-base);
    }

    .give-methods {
      grid-template-columns: 1fr;
    }
  }
</style>
