---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';

const title = 'Give | First Ithaca Chinese Christian Church';
const description =
  'Support the mission of First Ithaca Chinese Christian Church through your generous giving.';
---

<BaseLayout title={title} description={description}>
  <main id="main-content" data-pagefind-body>
    <Hero
      title="Give"
      subtitle="Your generosity makes a difference"
      backgroundImage="/images/hero/giving.webp"
    />

    <!-- Why We Give -->
    <section class="give-section" aria-label="Why We Give">
      <div class="give-section__inner">
        <h2 class="section-heading" data-reveal>Why We Give</h2>
        <div class="give-prose" data-reveal>
          <p>
            Giving is an act of worship and trust. When we give generously, we
            participate in God's work: supporting our church community, caring
            for those in need, and sharing the good news of Jesus Christ.
          </p>
          <blockquote class="give-verse">
            <p>
              "Each of you should give what you have decided in your heart to
              give, not reluctantly or under compulsion, for God loves a
              cheerful giver."
            </p>
            <cite>2 Corinthians 9:7 (NIV)</cite>
          </blockquote>
          <p>
            Whether it's your first time giving or you've been supporting our
            church for years, every gift helps us continue serving our community
            in Ithaca and beyond. Thank you for your faithfulness.
          </p>
        </div>
      </div>
    </section>

    <!-- Ways to Give -->
    <section class="give-section give-section--alt" aria-label="Ways to Give">
      <div class="give-section__inner">
        <h2 class="section-heading" data-reveal>Ways to Give</h2>
        <div class="give-methods" data-reveal-stagger>

          <!-- Online via PayPal -->
          <div class="give-method" data-reveal>
            <div class="give-method__icon" aria-hidden="true">💳</div>
            <h3 class="give-method__title">Online via PayPal</h3>
            <p class="give-method__desc">
              Give securely online using PayPal. You can use a PayPal account,
              debit card, or credit card.
            </p>
            <a
              class="give-method__link"
              href="https://www.paypal.com/donate/?hosted_button_id=PLACEHOLDER"
              target="_blank"
              rel="noopener noreferrer"
            >
              Give with PayPal →
            </a>
          </div>

          <!-- By Check -->
          <div class="give-method" data-reveal>
            <div class="give-method__icon" aria-hidden="true">✉️</div>
            <h3 class="give-method__title">By Check</h3>
            <p class="give-method__desc">
              Make checks payable to <strong>First Ithaca Chinese Christian
              Church</strong> and mail to:
            </p>
            <address class="give-method__address">
              First Ithaca Chinese Christian Church<br />
              429 Mitchell Street<br />
              Ithaca, NY 14850
            </address>
          </div>

          <!-- In Person -->
          <div class="give-method" data-reveal>
            <div class="give-method__icon" aria-hidden="true">🏠</div>
            <h3 class="give-method__title">In Person</h3>
            <p class="give-method__desc">
              Offering envelopes are available at our Sunday service. You can
              place your gift in the offering box located in the sanctuary.
            </p>
            <p class="give-method__note">
              Sundays at 9:45 AM · 429 Mitchell Street
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- Questions -->
    <section class="give-section" aria-label="Questions about Giving">
      <div class="give-section__inner give-section__centered">
        <h2 class="section-heading" data-reveal>Questions?</h2>
        <p class="give-prose" data-reveal>
          If you have questions about giving, tax-deductible receipts, or other
          ways to support our church, please don't hesitate to
          <a href="/en/contact">contact us</a>. We're happy to help.
        </p>
      </div>
    </section>
  </main>
</BaseLayout>

<style>
  .section-heading {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    color: var(--color-ink);
    text-align: center;
    margin-block-end: var(--space-10);
  }

  .give-section {
    padding: var(--space-16) var(--space-6);
    background-color: var(--color-bg);
  }

  .give-section--alt {
    background-color: var(--color-stone);
  }

  .give-section__inner {
    max-width: var(--max-width);
    margin-inline: auto;
  }

  .give-section__centered {
    text-align: center;
  }

  /* ---------- Prose ---------- */
  .give-prose {
    max-width: 42rem;
    margin-inline: auto;
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
  }

  .give-prose p {
    margin-block-end: var(--space-4);
  }

  .give-prose p:last-child {
    margin-block-end: 0;
  }

  .give-prose a {
    color: var(--color-terracotta);
    text-decoration: underline;
  }

  .give-prose a:hover {
    color: #b3654b;
  }

  /* ---------- Verse ---------- */
  .give-verse {
    border-inline-start: 3px solid var(--color-terracotta);
    padding: var(--space-6) var(--space-8);
    margin: var(--space-8) 0;
    background-color: var(--color-stone);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .give-verse p {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-style: italic;
    line-height: var(--leading-relaxed);
    color: var(--color-ink);
    margin-block-end: var(--space-2);
  }

  .give-verse cite {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    color: var(--color-body);
  }

  /* ---------- Methods Grid ---------- */
  .give-methods {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-8);
  }

  .give-method {
    background-color: var(--color-bg);
    border-radius: var(--radius-md);
    border: 1px solid rgba(26, 26, 46, 0.08);
    padding: var(--space-8) var(--space-6);
    text-align: center;
  }

  .give-method__icon {
    font-size: 2rem;
    margin-block-end: var(--space-4);
  }

  .give-method__title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin-block-end: var(--space-3);
  }

  .give-method__desc {
    font-family: var(--font-body);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--color-body);
    margin-block-end: var(--space-4);
  }

  .give-method__desc strong {
    color: var(--color-ink);
  }

  .give-method__link {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-bg);
    background-color: var(--color-terracotta);
    padding: var(--space-3) var(--space-8);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color var(--transition), transform var(--transition);
  }

  .give-method__link:hover {
    background-color: #b3654b;
    transform: translateY(-1px);
  }

  .give-method__link:focus-visible {
    outline: 2px solid var(--color-focus);
    outline-offset: 2px;
  }

  .give-method__address {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-style: normal;
    line-height: var(--leading-relaxed);
    color: var(--color-body);
  }

  .give-method__note {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    color: var(--color-terracotta);
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .section-heading {
      font-size: var(--text-2xl);
    }

    .give-methods {
      grid-template-columns: 1fr;
    }
  }
</style>
