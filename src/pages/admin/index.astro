---
/**
 * Sanity Studio embedded at /admin — client-only React component.
 * No SSR needed; the Studio renders entirely in the browser.
 */
import Studio from '../../components/Studio';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FICCC Studio</title>
    <style>
      html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        width: 100%;
        overflow: hidden;
      }
      #studio-root {
        height: 100vh;
        width: 100vw;
      }
    </style>
  </head>
  <body>
    <div id="studio-root">
      <Studio client:only="react" />
    </div>
  </body>
</html>
