  "version": "1.0.0",
  "private": true,
  "description": "First Ithaca Chinese Christian Church — unified bilingual website",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "npx serve dist/client -l 4321",
