    "@fontsource-variable/lora": "^5.2.8",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@sanity/astro": "^3.3.1",
    "@sanity/client": "^7.3.0",
    "@sanity/vision": "^5.18.0",
    "astro": "^5.5.5",
    "astro-pagefind": "^1.8.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "resend": "^6.10.0",
    "sanity": "^5.18.0"
  },
  "devDependencies": {
    "@axe-core/cli": "^4.11.1",
    "@lhci/cli": "^0.15.1",
